import { Controller } from '@hotwired/stimulus';

export default class extends Controller {
  static targets = ['unlimited', 'stock'];

  connect() {
    this.toggle();
  }

  toggle() {
    const unlimited = this.unlimitedTarget.checked;

    this.stockTarget.disabled = unlimited;
    if (unlimited) {
      this.stockTarget.value = '';
    }
  }
}
