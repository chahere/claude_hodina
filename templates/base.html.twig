<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}Hodina{% endblock %}</title>

    <link rel="icon" href="{{ asset('favicon.ico') }}?v=j5y-d-ter" sizes="any">
    <link rel="shortcut icon" href="{{ asset('favicon.ico') }}?v=j5y-d-ter">
    <link rel="icon" type="image/png" href="{{ asset('images/favicon-16x16.png') }}?v=j5y-d-ter" sizes="16x16">
    <link rel="icon" type="image/png" href="{{ asset('images/favicon-32x32.png') }}?v=j5y-d-ter" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ asset('images/apple-touch-icon.png') }}?v=j5y-d-ter">

    {# ?v= : casse le cache navigateur (Safari iOS le garde agressivement en
       navigation normale, contrairement aux fenêtres privées utilisées en
       test desktop). À incrémenter à chaque modification notable de ce
       fichier — cf. favicons ci-dessus pour la même convention. #}
    <link rel="stylesheet" href="{{ asset('css/style_mobile.css') }}?v=j5ae-widget-4">

    {% block stylesheets %}{% endblock %}
</head>
<body>

<header class="site-header">
    {% set cartCount = app.session.get('cart', [])|reduce((carry, qty) => carry + qty, 0) %}
    <div class="container header-inner">
        <a class="brand" href="{{ path('product_catalogue') }}">
            <img src="{{ asset('images/logo_hodina_header.png') }}" alt="Hodina" class="brand-logo">
        </a>

        <nav class="nav">
            {% if is_granted('ROLE_ADMIN') %}
                <a class="nav-link" href="/ouegnewe">
                    Admin
                </a>
            {% elseif is_granted('ROLE_COURIER') %}
                <a class="nav-link" href="{{ path('courier_dashboard') }}">
                    Livreur
                </a>
            {% else %}
                <a class="nav-link" href="{{ path('app_carnet_livraison') }}">
                    Infos livraison
                </a>
            {% endif %}
            {# Auth client #}
            {% if app.user %}
                <div class="account-menu" data-account-menu>
                    <button class="nav-icon-link account-icon account-menu__trigger"
                        type="button"
                        aria-label="Ouvrir le menu du compte"
                        aria-haspopup="true"
                        aria-expanded="false"
                        data-account-menu-trigger>
                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="4"/>
                            <circle cx="32" cy="25" r="7" fill="currentColor"/>
                            <path d="M20 46C22.5 39.5 27 36 32 36C37 36 41.5 39.5 44 46"
                                fill="currentColor"/>
                        </svg>
                    </button>

                    <div class="account-menu__panel" data-account-menu-panel hidden>
                        <a href="{{ path('client_account_index') }}">Mon compte</a>
                        <a href="{{ path('app_logout') }}">Se déconnecter</a>
                    </div>
                </div>
            {% else %}
                <a class="nav-icon-link login-icon"
                href="{{ path('app_login') }}"
                aria-label="Connexion"
                title="Connexion">

                    <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="38" cy="32" r="24" stroke="currentColor" stroke-width="4"/>
                        <circle cx="38" cy="26" r="7" fill="currentColor"/>
                        <path d="M26 44C28 39 33 36 38 36C43 36 48 39 50 44"
                            fill="currentColor"/>
                        <path d="M4 32H28" stroke="currentColor" stroke-width="4"/>
                        <path d="M18 18L32 32L18 46"
                            stroke="currentColor"
                            stroke-width="4"
                            stroke-linecap="round"
                            stroke-linejoin="round"/>
                    </svg>
                </a>
            {% endif %}

            <a class="nav-cart-icon" href="{{ path('cart_index') }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 3h2l2.4 10.2a1 1 0 0 0 1 .8h9.8a1 1 0 0 0 1-.8L21 6H7"/>
                <circle cx="10" cy="20" r="1"/>
                <circle cx="18" cy="20" r="1"/>
            </svg>

            <span class="cart-badge{% if cartCount is not defined or cartCount <= 0 %} is-empty{% endif %}" data-cart-badge>{{ cartCount|default(0) }}</span>
                </a>
        </nav>
    </div>
</header>

{% include 'launch/_countdown_banner.html.twig' %}

{% for label, messages in app.flashes %}
    <div class="container flash-list">
        {% for message in messages %}
            <div class="flash flash-{{ label }}">{{ message }}</div>
        {% endfor %}
    </div>
{% endfor %}

<main class="site-main">
    {% block body %}{% endblock %}
</main>

<footer class="site-footer" aria-labelledby="footer-hodina-title">
    <div class="container footer-reassurance" aria-label="Repères Hodina">
        <span>Produits locaux</span>
        <span>Vendeurs de Mayotte</span>
        <span>Livraison selon commune</span>
        <span>Paiement manuel pilote</span>
    </div>

    <div class="container footer-inner footer-grid">
        <nav class="footer-links" aria-label="Explorer Hodina">
            <h2 class="footer-heading">Explorer</h2>
            <a href="{{ path('product_catalogue') }}">Catalogue</a>
            <a href="{{ path('app_discover_hodina') }}">Découvrir Hodina</a>
            <a href="{{ path('app_carnet') }}">Carnet Hodina</a>
        </nav>

        <nav class="footer-links" aria-label="Livraison Hodina">
            <h2 class="footer-heading">Livraison</h2>
            <a href="{{ path('app_carnet_livraison') }}">Infos livraison</a>
            <a href="{{ path('app_carnet_livraison') }}#modes">Points de remise</a>
            <a href="{{ path('cart_index') }}">Dates confirmées au panier</a>
        </nav>

        <section class="footer-links footer-practical" aria-label="Informations pratiques">
            <h2 class="footer-heading">Pratique</h2>
            <a href="{{ path('app_cgv') }}">CGV</a>
            <a href="{{ path('app_cgu') }}">CGU</a>
            <a href="{{ path('app_contact') }}">Nous contacter</a>
            <a href="mailto:contact@hodina.fr" class="footer-contact">contact@hodina.fr</a>
        </section>
    </div>

    <div class="container footer-bottom">
        <span>© Hodina à Mayotte</span>
        <span>Les frais, dates et créneaux exacts sont confirmés au panier.</span>
    </div>
</footer>

{% block chat_widget %}
    {% include 'support/_chat_widget.html.twig' %}
{% endblock %}

<script>
(function () {
    const menu = document.querySelector('[data-account-menu]');
    if (!menu) {
        return;
    }

    const trigger = menu.querySelector('[data-account-menu-trigger]');
    const panel = menu.querySelector('[data-account-menu-panel]');

    if (!trigger || !panel) {
        return;
    }

    const closeMenu = function () {
        panel.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
    };

    const openMenu = function () {
        panel.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        menu.classList.add('is-open');
    };

    trigger.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();

        if (panel.hidden) {
            openMenu();
            return;
        }

        closeMenu();
    });

    document.addEventListener('click', function (event) {
        if (!menu.contains(event.target)) {
            closeMenu();
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeMenu();
        }
    });
})();
</script>

{% block javascripts %}{% endblock %}
<script>
(function () {
    const formsSelector = 'form[data-ajax-cart-form]';
    let toastTimer = null;

    const ensureToast = () => {
        let toast = document.querySelector('[data-cart-toast]');
        if (toast) return toast;

        toast = document.createElement('div');
        toast.setAttribute('data-cart-toast', '');
        toast.setAttribute('role', 'status');
        toast.setAttribute('aria-live', 'polite');
        toast.style.position = 'fixed';
        toast.style.left = '50%';
        toast.style.bottom = '18px';
        toast.style.transform = 'translateX(-50%) translateY(120%)';
        toast.style.zIndex = '9999';
        toast.style.maxWidth = 'calc(100vw - 24px)';
        toast.style.padding = '.8rem 1rem';
        toast.style.borderRadius = '999px';
        toast.style.background = '#111827';
        toast.style.color = '#fff';
        toast.style.fontWeight = '800';
        toast.style.boxShadow = '0 14px 35px rgba(0,0,0,.25)';
        toast.style.opacity = '0';
        toast.style.transition = 'opacity .18s ease, transform .18s ease';
        document.body.appendChild(toast);

        return toast;
    };

    const showToast = (message, type) => {
        const toast = ensureToast();
        toast.textContent = message || 'Panier mis à jour.';
        toast.style.background = type === 'error' ? '#991b1b' : '#111827';
        toast.style.opacity = '1';
        toast.style.transform = 'translateX(-50%) translateY(0)';

        window.clearTimeout(toastTimer);
        toastTimer = window.setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(-50%) translateY(120%)';
        }, 2300);
    };

    const updateCartBadge = (count) => {
        const numericCount = Math.max(0, parseInt(count, 10) || 0);
        let badge = document.querySelector('[data-cart-badge]');
        const cartLink = document.querySelector('.nav-cart-icon');

        if (!badge && cartLink) {
            badge = document.createElement('span');
            badge.className = 'cart-badge';
            badge.setAttribute('data-cart-badge', '');
            cartLink.appendChild(badge);
        }

        if (!badge) return;

        badge.textContent = String(numericCount);
        badge.classList.toggle('is-empty', numericCount <= 0);
        badge.style.display = numericCount > 0 ? '' : 'none';
    };

    const setSubmitting = (form, isSubmitting) => {
        const submit = form.querySelector('[type="submit"]');
        if (!submit) return;

        if (isSubmitting) {
            submit.dataset.originalLabel = submit.textContent.trim();
            submit.disabled = true;
            submit.textContent = 'Ajout...';
        } else {
            submit.disabled = submit.dataset.originalDisabled === '1';
            submit.textContent = submit.dataset.originalLabel || submit.textContent;
        }
    };

    document.addEventListener('submit', async (event) => {
        const form = event.target.closest(formsSelector);
        if (!form) return;

        event.preventDefault();

        if (form.dataset.ajaxSubmitting === '1') return;
        form.dataset.ajaxSubmitting = '1';

        const submit = form.querySelector('[type="submit"]');
        if (submit && !submit.dataset.originalDisabled) {
            submit.dataset.originalDisabled = submit.disabled ? '1' : '0';
        }

        setSubmitting(form, true);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                credentials: 'same-origin',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            const data = await response.json().catch(() => null);
            if (!response.ok || !data || data.ok === false) {
                throw new Error(data && data.message ? data.message : 'Impossible d’ajouter ce produit au panier.');
            }

            updateCartBadge(data.cartCount);
            showToast(data.message || 'Produit ajouté au panier.', 'success');
        } catch (error) {
            showToast(error.message || 'Erreur pendant l’ajout au panier.', 'error');
        } finally {
            form.dataset.ajaxSubmitting = '0';
            setSubmitting(form, false);
        }
    });

    updateCartBadge(document.querySelector('[data-cart-badge]')?.textContent || 0);
})();
</script>
<style>
    .cart-badge.is-empty { display: none; }
</style>
</body>
</html>
