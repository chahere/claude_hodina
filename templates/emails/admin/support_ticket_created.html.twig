<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Nouveau ticket support Hodina</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.5; color: #1f2933;">
    <h1 style="font-size: 22px; margin-bottom: 8px;">Nouveau ticket support</h1>

    <p>{{ emailBranding.opening|default('Bonjour,') }}</p>

    <p>
        Origine : <strong>{{ ticket.origin }}</strong><br>
        Sujet : <strong>{{ ticket.subject }}</strong><br>
        Contact : {{ ticket.contactName }} ({{ ticket.contactEmail }}){% if ticket.contactPhone %} — {{ ticket.contactPhone }}{% endif %}<br>
        Créé le : {{ ticket.createdAt|date('d/m/Y H:i') }}
    </p>

    {% if firstMessage %}
        <h2 style="font-size: 18px; margin-top: 20px;">Message</h2>
        <p style="white-space: pre-line; border-left: 3px solid #d8dee9; padding-left: 12px;">{{ firstMessage.content }}</p>
    {% endif %}

    <p style="margin-top: 20px;">
        Action requise : connecte-toi à <strong>EasyAdmin &gt; Support &gt; Tickets support</strong>
        pour répondre puis clôturer le ticket une fois traité.
    </p>

    <p>
        {{ emailBranding.closing|default('Merci,') }}<br>
        {{ emailBranding.signature|default('L’équipe Hodina') }}
    </p>
</body>
</html>
