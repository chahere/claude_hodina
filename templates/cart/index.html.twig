{% extends 'base.html.twig' %}

{% block title %}Panier – Hodina{% endblock %}

{% block body %}
{% set salesOpening = hodina_commerce_state() %}
<section class="cart-page">
  <div class="container">

    <div class="cart-info-flash cart-info-flash--delivery-fee cart-info-flash--page-top" data-delivery-fee-update-flash role="status" aria-live="polite" hidden>
      <button type="button" class="cart-info-flash-close" data-dismiss-delivery-fee-update aria-label="Fermer le message">×</button>
      <strong>Frais de livraison mis à jour</strong>
      <p>Selon ta nouvelle adresse, Hodina a recalculé les frais. Le détail apparaît sous “Frais de livraison”.</p>
    </div>

    <div class="cart-head">
      <h1 class="cart-title">Mon panier</h1>
      <p class="cart-sub muted">Vérifie tes produits, choisis ton adresse de livraison et valide ta commande depuis le panier.</p>
    </div>

    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ label }}">{{ message }}</div>
      {% endfor %}
    {% endfor %}

    {% set checkout_has_errors = form is defined and form.vars.submitted|default(false) and not form.vars.valid %}
    {% if checkout_has_errors %}
      <div class="checkout-global-alert alert alert-danger" data-checkout-server-alert role="alert" aria-live="assertive">
        <strong>Impossible de valider ta commande pour le moment.</strong>
        <p>Corrige les informations ci-dessous, puis réessaie.</p>
        <ul>
          {% for error in form.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.firstName.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.lastName.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.phone.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.email.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.deliveryPointId.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.deliveryPointRequestedDate.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.deliveryPointRequestedTime.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.deliveryPointTimeWindowId.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.address.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.commune.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.postalCode.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.localityText.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
          {% for error in form.acceptTerms.vars.errors %}
            <li>{{ error.message }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <div class="checkout-client-alert alert alert-danger" data-checkout-client-alert role="status" aria-live="polite" hidden>
      <strong data-checkout-client-alert-title>Commande incomplète</strong>
      <p data-checkout-client-alert-message>Complète les informations obligatoires pour valider.</p>
    </div>

    {% if cart.items is empty %}
      <div class="empty-state">
        <p><strong>Ton panier est vide.</strong></p>
        <a class="btn btn-primary" href="{{ path('product_catalogue') }}">Voir le catalogue</a>
      </div>
    {% else %}

      {{ form_start(form, {
        'action': path('checkout_index'),
        'attr': {
          'id': 'checkout-form',
          'class': 'cart-layout cart-layout--linear',
          'data-cart-update-url': path('cart_update'),
          'novalidate': 'novalidate'
        }
      }) }}
        {% set point_options = deliveryPointOptions|default({}) %}
        {% set point_choices = deliveryPointChoices|default([]) %}
        {% set current_delivery_method = form.deliveryMethod.vars.value|default('') %}
        {% if current_delivery_method is empty %}
          {% set current_delivery_method = point_options.requiresDeliveryPoint|default(false) ? 'DELIVERY_POINT' : 'STANDARD' %}
        {% endif %}
        {% set uses_delivery_point_mode = point_options.requiresDeliveryPoint|default(false) or current_delivery_method == 'DELIVERY_POINT' %}
        {% set schedule_preview = deliverySchedulePreview|default(null) %}
        {% set has_appointment_delivery_promise = cartHasAppointmentDeliveryPromise|default(false) %}
        {% set address_localities = addressLocalities|default([]) %}
        {% if address_localities is not empty %}

          <style>
            .address-locality-suggestion-list {
              display: grid;
              gap: 6px;
              margin-top: 8px;
            }
            .address-locality-suggestion-list[hidden] {
              display: none;
            }
            .address-locality-suggestion-button {
              width: 100%;
              border: 1px solid rgba(0, 0, 0, .14);
              border-radius: 12px;
              background: #fff;
              padding: 10px 12px;
              text-align: left;
              font: inherit;
              cursor: pointer;
            }
            .address-locality-suggestion-button strong {
              display: block;
            }
            .address-locality-suggestion-button span {
              display: block;
              margin-top: 2px;
            }
          </style>

          <datalist id="checkout-address-locality-suggestions">
            {% for locality in address_localities %}
              {% set locality_commune = locality.deliveryCommune %}
              <option
                value="{{ locality.name|e('html_attr') }}"
                data-locality-id="{{ locality.id }}"
                data-postal-code="{{ locality.postalCode|default('')|e('html_attr') }}"
                data-commune="{{ locality_commune ? locality_commune.name|e('html_attr') : '' }}"
              >{{ locality.name }}{% if locality_commune %} — {{ locality_commune.name }}{% endif %}</option>
            {% endfor %}
          </datalist>
        {% endif %}
        <div class="cart-main-column">
          <section class="cart-step cart-step--products" aria-labelledby="cart-step-products-title">
            <div class="cart-step-head">
              <span class="cart-step-index">1</span>
              <div>
                <h2 id="cart-step-products-title" class="cart-step-title">Mes produits</h2>
                <p class="cart-step-sub muted">Ajuste les quantités. Les changements sont synchronisés automatiquement.</p>
              </div>
            </div>

            <div class="cart-items">
          {% for item in cart.items %}
            {% set p = item.product %}

            <article class="cart-card">
              <div class="cart-card-media">
                {% set img = null %}
                {% if p.images is defined and p.images|length > 0 %}
                  {% set img = p.images|first %}
                {% endif %}

                {% if img %}
                  <img class="cart-card-img" src="{{ asset('uploads/products/' ~ img.path) }}" alt="{{ p.name }}" loading="lazy">
                {% else %}
                  <div class="cart-card-img cart-card-img--ph" aria-hidden="true">🛍️</div>
                {% endif %}
              </div>

              <div class="cart-card-body">
                <div class="cart-card-top">
                  <a class="cart-card-name" href="{{ path('product_show', {slug: p.slug}) }}">{{ p.name }}</a>

                  <div class="cart-card-meta muted">
                    {% if p.seller is defined and p.seller %}
                      <span class="cart-seller-badge">{{ p.seller.publicDisplayName }}</span>
                    {% endif %}
                  </div>
                </div>

                <div class="cart-card-bottom">
                  <div class="cart-card-price">
                    <div class="muted small">Prix</div>
                    <div class="price">{{ item.unitPrice|number_format(2, ',', ' ') }} € <span class="cart-card-unit">{{ p.unitLabel|lower }}</span></div>
                  </div>

                  <div class="cart-card-qty">
                    <div class="muted small">Qté</div>

                    <div class="qty-stepper qty-stepper--sm" data-cart-stepper>
                      <button type="button" data-minus aria-label="Diminuer">−</button>

                      <input
                        class="qty-stepper-input"
                        type="number"
                        min="0"
                        max="99"
                        name="qty[{{ p.id }}]"
                        value="{{ item.qty }}"
                        inputmode="numeric"
                        aria-label="Quantité {{ p.name }}"
                        data-qty
                      >

                      <button type="button" data-plus aria-label="Augmenter">+</button>
                    </div>
                  </div>

                  <div class="cart-card-subtotal">
                    <div class="muted small">Sous-total</div>
                    <div class="price" data-line-total data-unit-price="{{ item.unitPrice }}">
                      {{ item.lineTotal|number_format(2, ',', ' ') }} €
                    </div>
                  </div>
                </div>

                <div class="cart-card-actions">
                  <button
                    class="btn btn-link danger"
                    type="button"
                    data-remove-line
                    data-product-id="{{ p.id }}"
                  >
                    Retirer
                  </button>
                </div>
              </div>
            </article>
          {% endfor %}
            </div>
          </section>

          <section class="summary-card cart-step cart-step--totals" aria-labelledby="cart-step-totals-title">
            <div class="cart-step-head">
              <span class="cart-step-index">2</span>
              <div>
                <h2 id="cart-step-totals-title" class="cart-step-title">Total du panier</h2>
                <p class="cart-step-sub muted">Vérifie le total des articles et les frais de livraison avant de confirmer tes informations.</p>
              </div>
            </div>


            <div class="summary-row">
              <span class="muted">Articles</span>
              <strong data-cart-total-qty>{{ cart.totalQty }}</strong>
            </div>

            <div class="summary-row">
              <span>Total produits</span>
              <strong data-cart-total data-checkout-products-total data-products-total="{{ cart.total }}">{{ cart.total|number_format(2, ',', ' ') }} €</strong>
            </div>

            <div
              id="checkout-logistics-preview"
              class="cart-logistics-preview cart-logistics-preview--simple {{ logisticsPreview is defined and logisticsPreview and logisticsPreview.requiresBarge ? 'is-barge' : '' }}"
              data-preview-url="{{ path('cart_logistics_preview') }}"
              aria-live="polite"
            >
              <p class="cart-logistics-message" data-logistics-message>
                {% if logisticsPreview is defined and logisticsPreview %}
                  {{ logisticsPreview.message }}
                {% else %}
                  Choisis une commune livrée pour recalculer les frais de livraison.
                {% endif %}
              </p>
              <div class="summary-row cart-logistics-fee" data-logistics-fee-row {% if logisticsPreview is not defined or not logisticsPreview or logisticsPreview.estimatedDeliveryFee is null %}hidden{% endif %}>
                <span>Frais de livraison</span>
                <strong data-logistics-fee>{{ logisticsPreview is defined and logisticsPreview and logisticsPreview.estimatedDeliveryFee is not null ? logisticsPreview.estimatedDeliveryFee|number_format(2, ',', ' ') ~ ' €' : '' }}</strong>
              </div>
              {% set logistics_fee_reasons = [] %}
              {% set logistics_land_hops = logisticsPreview is defined and logisticsPreview ? logisticsPreview.landHopCount|default(0) : 0 %}
              {% if logistics_land_hops > 0 %}
                {% set logistics_fee_reasons = logistics_fee_reasons|merge([logistics_land_hops ~ ' commune' ~ (logistics_land_hops > 1 ? 's' : '') ~ ' traversée' ~ (logistics_land_hops > 1 ? 's' : '')]) %}
              {% elseif logisticsPreview is defined and logisticsPreview and logisticsPreview.collectionPointCount|default(0) > 1 %}
                {% set logistics_fee_reasons = logistics_fee_reasons|merge(['plusieurs communes de collecte']) %}
              {% endif %}
              {% if logisticsPreview is defined and logisticsPreview and (logisticsPreview.requiresBarge|default(false) or logisticsPreview.bargeHopCount|default(0) > 0) %}
                {% set logistics_fee_reasons = logistics_fee_reasons|merge(['barge']) %}
              {% endif %}
              <p class="cart-logistics-fee-note" data-logistics-fee-reason {% if logistics_fee_reasons is empty %}hidden{% endif %}>
                {{ logistics_fee_reasons is not empty ? 'Inclus : ' ~ logistics_fee_reasons|join(' + ') ~ '.' : '' }}
              </p>
              <div class="summary-row summary-total cart-logistics-total" data-logistics-total-row {% if logisticsPreview is not defined or not logisticsPreview or logisticsPreview.estimatedDeliveryFee is null %}hidden{% endif %}>
                <span>Total estimé</span>
                <strong data-logistics-total>{{ logisticsPreview is defined and logisticsPreview and logisticsPreview.estimatedDeliveryFee is not null ? (cart.total + logisticsPreview.estimatedDeliveryFee)|number_format(2, ',', ' ') ~ ' €' : '' }}</strong>
              </div>
            </div>

            <div class="summary-actions summary-actions--secondary">
              <button class="btn btn-secondary" type="submit" formaction="{{ path('cart_update') }}" formnovalidate>Mettre à jour les quantités</button>

              <button
                class="btn btn-link danger"
                type="button"
                data-clear-cart
              >
                Vider le panier
              </button>
            </div>
          </section>
          {% if app.user %}
          <section class="summary-card cart-step cart-step--delivery" aria-labelledby="cart-step-delivery-title">
            <div class="cart-step-head">
              <span class="cart-step-index">3</span>
              <div>
                <h2 id="cart-step-delivery-title" class="cart-step-title">Livraison</h2>
                <p class="cart-step-sub muted">Confirme l’adresse où le livreur doit te retrouver.</p>
              </div>
            </div>

            {% if app.user %}
              <div class="point" style="margin-bottom:12px;">
                <strong>Connecté avec ton compte Hodina</strong>
                <p class="muted small">Ta commande sera rattachée à ton compte.</p>
                <div class="checkout-account-summary">
                  <div><strong>{{ app.user.firstName }} {{ app.user.lastName }}</strong></div>
                  <div class="muted small">{{ app.user.email }}</div>
                  <div class="muted small">{{ app.user.phone }}</div>
                </div>
              </div>

              <div style="display:none;">
                {{ form_row(form.firstName) }}
                {{ form_row(form.lastName) }}
                {{ form_row(form.phoneCountryCode) }}
                {{ form_row(form.phone) }}
                {{ form_row(form.email) }}
              </div>
            {% else %}
              <p class="muted small">Renseigne tes infos. Pendant le pilote, un admin valide la commande avant livraison.</p>
              {{ form_row(form.firstName) }}
              {{ form_row(form.lastName) }}
              {{ form_row(form.phoneCountryCode) }}
              {{ form_row(form.phone) }}

              <div class="client-form-field{% if form.email.vars.errors|length > 0 %} has-error{% endif %}">
                {{ form_label(form.email, null, {'label_attr': {'class': 'client-form-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'client-form-control'}}) }}
                {% if form.email.vars.errors|length > 0 %}
                  <div class="client-form-errors">{{ form_errors(form.email) }}</div>
                {% endif %}
              </div>
            {% endif %}

            {{ form_widget(form.existingAddressId) }}
            {{ form_widget(form.addressLocalityId) }}
            {{ form_widget(form.billingExistingAddressId) }}
            <div style="display:none;">
              {{ form_widget(form.deliveryMethod) }}
              {{ form_widget(form.deliveryPointId) }}
              {{ form_widget(form.deliveryPointTimeWindowId) }}
              {% if not point_options.hasDeliveryPointProducts|default(false) %}
                {{ form_widget(form.deliveryPointRequestedDate) }}
                {{ form_widget(form.deliveryPointRequestedTime) }}
                {{ form_widget(form.deliveryPointCustomerInstructions) }}
              {% endif %}
            </div>

            {% set point_options = deliveryPointOptions|default({}) %}
            {% set point_choices = deliveryPointChoices|default([]) %}
            {% if point_options.hasDeliveryPointProducts|default(false) %}
              <div
                class="delivery-point-choice point"
                data-delivery-point-section
                data-point-required="{{ point_options.requiresDeliveryPoint|default(false) ? '1' : '0' }}"
              >
                <strong>Point de remise Hodina</strong>
                {% if point_options.requiresDeliveryPoint|default(false) %}
                  <p class="muted small">Ce panier contient un produit qui impose une remise dans un point précis. Choisis le lieu, puis indique la date et l’heure où tu seras sur place.</p>
                {% else %}
                  <p class="muted small">Tu peux choisir une livraison à ton adresse ou une remise dans un point Hodina.</p>
                  <div class="delivery-method-toggle" role="group" aria-label="Mode de livraison">
                    <button
                      type="button"
                      class="delivery-method-btn{{ current_delivery_method == 'STANDARD' ? ' is-selected' : '' }}"
                      data-delivery-method="STANDARD"
                      aria-pressed="{{ current_delivery_method == 'STANDARD' ? 'true' : 'false' }}"
                    >Livraison à mon adresse</button>
                    <button
                      type="button"
                      class="delivery-method-btn{{ current_delivery_method == 'DELIVERY_POINT' ? ' is-selected' : '' }}"
                      data-delivery-method="DELIVERY_POINT"
                      aria-pressed="{{ current_delivery_method == 'DELIVERY_POINT' ? 'true' : 'false' }}"
                    >Point de remise</button>
                  </div>
                {% endif %}

                {% if point_options.conflictMessage|default(null) %}
                  <div class="alert alert-warning">{{ point_options.conflictMessage }}</div>
                {% endif %}

                {% if point_choices is not empty %}
                  <div data-delivery-point-mode-panel{% if not uses_delivery_point_mode %} hidden{% endif %}>
                  <div class="delivery-point-cards" data-delivery-point-cards>
                    {% for point in point_choices %}
                      <button
                        type="button"
                        class="delivery-point-card"
                        data-delivery-point-card
                        data-point-id="{{ point.id }}"
                        data-point-name="{{ point.name|e('html_attr') }}"
                        data-line1="{{ point.line1|e('html_attr') }}"
                        data-line2="{{ point.line2|default('')|e('html_attr') }}"
                        data-postal-code="{{ point.postalCode|default('')|e('html_attr') }}"
                        data-commune="{{ point.commune|default('')|e('html_attr') }}"
                        data-zone="{{ point.zone|default('')|e('html_attr') }}"
                        data-gps-latitude="{{ point.gpsLatitude|default('') }}"
                        data-gps-longitude="{{ point.gpsLongitude|default('') }}"
                        data-gps-accuracy="{{ point.gpsAccuracyMeters|default('') }}"
                        data-public-instructions="{{ point.publicInstructions|default('')|e('html_attr') }}"
                      >
                        <span class="delivery-point-card__type">{{ point.typeLabel }}</span>
                        <strong>{{ point.name }}</strong>
                        <span>{{ point.line1 }}</span>
                        <small>{{ point.postalCode }} {{ point.commune }}</small>
                        {% if point.publicInstructions %}
                          <small>{{ point.publicInstructions }}</small>
                        {% endif %}
                      </button>
                    {% endfor %}
                  </div>

                  <div class="delivery-point-windows-help" data-delivery-point-windows-help>
                    <strong>Horaires proposés</strong>
                    <p class="muted small">Choisis ensuite la date et l’heure exacte où tu seras au rendez-vous.</p>
                    {% if point_options.maximumOrderLeadTimeHours|default(0) > 0 %}
                      <div class="alert alert-info">Certains produits de ton panier doivent être commandés au moins {{ point_options.maximumOrderLeadTimeHours }} h avant le rendez-vous.</div>
                    {% endif %}
                    {% for point in point_choices %}
                      <ul class="delivery-point-window-list" data-delivery-point-window-list data-point-id="{{ point.id }}" hidden>
                        {% for window in point.timeWindows %}
                          <li data-window-id="{{ window.id }}" data-window-label="{{ window.label|e('html_attr') }}" data-window-start="{{ window.startTime }}" data-window-end="{{ window.endTime }}" data-window-weekday="{{ window.weekday|default('') }}">
                            {{ window.label }}
                          </li>
                        {% endfor %}
                      </ul>
                    {% endfor %}
                  </div>

                  <div class="guest-checkout-grid delivery-point-appointment-grid">
                    <div class="client-form-field delivery-point-appointment-field delivery-point-date-field{% if form.deliveryPointRequestedDate.vars.errors|length > 0 %} has-error{% endif %}">
                      {{ form_label(form.deliveryPointRequestedDate, null, {'label_attr': {'class': 'client-form-label'}}) }}
                      <div class="delivery-point-date-control">
                        {{ form_widget(form.deliveryPointRequestedDate, {'attr': {'class': 'client-form-control delivery-point-date-input', 'data-delivery-point-date-input': '1'}}) }}
                      </div>
                      {% if form.deliveryPointRequestedDate.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(form.deliveryPointRequestedDate) }}</div>
                      {% endif %}
                    </div>

                    <div class="client-form-field delivery-point-appointment-field delivery-point-slot-field{% if form.deliveryPointRequestedTime.vars.errors|length > 0 %} has-error{% endif %}" data-delivery-point-slot-field>
                      <label class="client-form-label">Créneau de remise</label>
                      {{ form_widget(form.deliveryPointRequestedTime, {'attr': {'data-delivery-point-time-input': '1'}}) }}
                      <div class="delivery-point-slot-control">
                        <select class="client-form-control delivery-point-slot-select" data-delivery-point-slot-select disabled aria-disabled="true">
                          <option value="">Choisis d’abord une date</option>
                        </select>
                      </div>
                      <p class="muted small" data-delivery-point-slot-help>Choisis une date pour afficher les créneaux disponibles.</p>
                      {% if form.deliveryPointRequestedTime.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(form.deliveryPointRequestedTime) }}</div>
                      {% endif %}
                    </div>
                  </div>

                  {% if form.deliveryPointTimeWindowId.vars.errors|length > 0 %}
                    <div class="client-form-errors">{{ form_errors(form.deliveryPointTimeWindowId) }}</div>
                  {% endif %}

                  <div class="client-form-field{% if form.deliveryPointCustomerInstructions.vars.errors|length > 0 %} has-error{% endif %}">
                    {{ form_label(form.deliveryPointCustomerInstructions, null, {'label_attr': {'class': 'client-form-label'}}) }}
                    {{ form_widget(form.deliveryPointCustomerInstructions, {'attr': {'class': 'client-form-control'}}) }}
                    <p class="muted small">Exemple : heure d’arrivée, vol, barge, repère ou personne à appeler.</p>
                    {% if form.deliveryPointCustomerInstructions.vars.errors|length > 0 %}
                      <div class="client-form-errors">{{ form_errors(form.deliveryPointCustomerInstructions) }}</div>
                    {% endif %}
                  </div>
                  </div>
                {% endif %}

                {% if form.deliveryPointId.vars.errors|length > 0 %}
                  <div class="client-form-errors">{{ form_errors(form.deliveryPointId) }}</div>
                {% endif %}
              </div>
            {% endif %}

            <div class="delivery-current-card cart-address-card" data-standard-delivery-summary{% if uses_delivery_point_mode %} hidden{% endif %}>
              <div class="cart-address-card__head">
                <strong>Adresse de livraison utilisée</strong>
                <button
                  type="button"
                  class="btn btn-link address-edit-btn"
                  id="edit-delivery-address"
                  aria-label="Modifier cette adresse de livraison"
                  title="Modifier cette adresse de livraison"
                >Changer</button>
              </div>
              <p class="muted small" style="margin:6px 0 0;" data-delivery-current-address>
                {{ form.address.vars.value ?: 'Adresse à compléter' }}
              </p>
              <p class="muted small" style="margin:2px 0 0;" data-delivery-current-locality>
                {{ form.localityText.vars.value ? 'Localité : ' ~ form.localityText.vars.value : 'Localité : non renseignée' }}
              </p>
              <p class="muted small" style="margin:2px 0 0;" data-delivery-current-commune>
                {{ form.postalCode.vars.value ? form.postalCode.vars.value ~ ' ' : '' }}{{ form.commune.vars.value ?: 'Commune à choisir' }}
              </p>
              <p class="muted small" style="margin:2px 0 0;" data-delivery-current-instructions>
                Instructions : non renseignées
              </p>
              {% set current_gps_latitude = form.gpsLatitude.vars.value|default('') %}
              {% set current_gps_longitude = form.gpsLongitude.vars.value|default('') %}
              {% set current_gps_accuracy = form.gpsAccuracyMeters.vars.value|default('') %}
              <div class="muted small cart-address-gps-line" style="margin:2px 0 0;" data-delivery-current-gps>
                <span class="cart-address-gps-label">GPS :</span>
                {% if current_gps_latitude and current_gps_longitude %}
                  <span class="cart-address-gps-value">
                    {{ current_gps_latitude }}, {{ current_gps_longitude }}{% if current_gps_accuracy %} (~{{ current_gps_accuracy|round }} m){% endif %}
                  </span>
                {% else %}
                  <button type="button" class="cart-address-gps-inline-btn" data-open-gps-field>Position GPS</button>
                {% endif %}
              </div>

