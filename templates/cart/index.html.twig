    <script>
      (function () {
        const form = document.getElementById('checkout-form');
        if (!form) return;

        const updateUrl = form.dataset.cartUpdateUrl;
        let syncTimer = null;
        let syncAbortController = null;

        const formatEuro = (amount) => {
          return new Intl.NumberFormat('fr-FR', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
          }).format(amount) + ' €';
        };

        const clamp = (n) => {
          n = parseInt(n, 10);
          if (Number.isNaN(n) || n < 0) n = 0;
          if (n > 99) n = 99;
          return n;
        };

        const syncCartToSession = () => {
          if (!updateUrl || !window.fetch) return;

          if (syncAbortController) {
            syncAbortController.abort();
          }

          syncAbortController = new AbortController();
          window.dispatchEvent(new CustomEvent('hodina:cart-sync-started'));

          const body = new URLSearchParams();
          form.querySelectorAll('[data-qty]').forEach(input => {
            body.set(input.name, input.value || '0');
          });

          fetch(updateUrl, {
            method: 'POST',
            headers: {
              'X-Requested-With': 'XMLHttpRequest',
              'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
            },
            body,
            signal: syncAbortController.signal
          })
            .then(() => window.dispatchEvent(new CustomEvent('hodina:cart-synced')))
            .catch((error) => {
              if (error && error.name === 'AbortError') return;
              window.dispatchEvent(new CustomEvent('hodina:cart-sync-failed'));
            });
        };

        const scheduleCartSync = () => {
          if (syncTimer) {
            window.clearTimeout(syncTimer);
          }

          syncTimer = window.setTimeout(syncCartToSession, 350);
        };

        const refreshTotals = () => {
          let totalQty = 0;
          let cartTotal = 0;

          document.querySelectorAll('[data-cart-stepper]').forEach(stepper => {
            const input = stepper.querySelector('[data-qty]');
            const card = stepper.closest('.cart-card');
            const lineTotalEl = card ? card.querySelector('[data-line-total]') : null;

            if (!input || !lineTotalEl) return;

            const qty = clamp(input.value);
            const unitPrice = parseFloat(String(lineTotalEl.dataset.unitPrice).replace(',', '.')) || 0;
            const lineTotal = qty * unitPrice;

            input.value = String(qty);
            lineTotalEl.textContent = formatEuro(lineTotal);

            totalQty += qty;
            cartTotal += lineTotal;
          });

          const totalQtyEl = document.querySelector('[data-cart-total-qty]');
          const cartTotalEl = document.querySelector('[data-cart-total]');
          const checkoutProductsTotalEl = document.querySelector('[data-checkout-products-total]');

          if (totalQtyEl) totalQtyEl.textContent = String(totalQty);
          if (cartTotalEl) cartTotalEl.textContent = formatEuro(cartTotal);
          if (checkoutProductsTotalEl) {
            checkoutProductsTotalEl.textContent = formatEuro(cartTotal);
            checkoutProductsTotalEl.dataset.productsTotal = String(cartTotal.toFixed(2));
          }

          const mobileTotalEl = document.querySelector('[data-cart-mobile-total]');
          const logisticsTotalEl = document.querySelector('[data-logistics-total]');
          if (mobileTotalEl && (!logisticsTotalEl || !logisticsTotalEl.textContent.trim())) {
            mobileTotalEl.textContent = formatEuro(cartTotal);
          }
        };

        document.querySelectorAll('[data-cart-stepper]').forEach(stepper => {
          const input = stepper.querySelector('[data-qty]');
          const minus = stepper.querySelector('[data-minus]');
          const plus = stepper.querySelector('[data-plus]');

          if (!input || !minus || !plus) return;

          const sync = (v) => {
            input.value = String(clamp(v));
            refreshTotals();
            scheduleCartSync();
          };

          minus.addEventListener('click', () => sync(clamp(input.value) - 1));
          plus.addEventListener('click', () => sync(clamp(input.value) + 1));

          input.addEventListener('input', () => {
            refreshTotals();
            scheduleCartSync();
          });
          input.addEventListener('blur', () => sync(input.value));
        });

        document.querySelectorAll('[data-remove-line]').forEach(btn => {
          btn.addEventListener('click', () => {
            const productId = btn.dataset.productId;
            const input = form.querySelector(`[name="qty[${productId}]"]`);

            if (input) {
              input.value = '0';
              refreshTotals();
              form.action = updateUrl;
              form.noValidate = true;
              form.submit();
            }
          });
        });

        const clearBtn = document.querySelector('[data-clear-cart]');
        if (clearBtn) {
          clearBtn.addEventListener('click', () => {
            form.querySelectorAll('[data-qty]').forEach(input => {
              input.value = '0';
            });

            refreshTotals();
            form.action = updateUrl;
            form.noValidate = true;
            form.submit();
          });
        }

        refreshTotals();
      })();
    </script>

    <script>
(function(){
  const form = document.getElementById('checkout-form');
  if(!form) return;

  const submitButtons = Array.from(form.querySelectorAll('[data-checkout-submit]'));
  if(submitButtons.length === 0) return;

  const existingAccountModal = document.querySelector('[data-existing-account-confirmation-modal]');
  const existingAccountConfirmButton = existingAccountModal ? existingAccountModal.querySelector('[data-existing-account-confirm]') : null;
  const existingAccountEditButtons = existingAccountModal ? Array.from(existingAccountModal.querySelectorAll('[data-existing-account-edit-email]')) : [];
  const confirmExistingAccountInput = form.querySelector('#checkout_confirmExistingAccount');
  const confirmedExistingAccountEmailInput = form.querySelector('#checkout_confirmedExistingAccountEmail');
  const emailInput = form.querySelector('#checkout_email');

  let checkoutSubmitAttempted = Boolean(document.querySelector('[data-checkout-server-alert]'));

  const showClientValidationAlert = () => {
    checkoutSubmitAttempted = true;
    refresh();

    const clientAlert = document.querySelector('[data-checkout-client-alert]');
    if (clientAlert && clientAlert.scrollIntoView) {
      window.setTimeout(() => {
        clientAlert.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 30);
    }
  };

  const hideExistingAccountModal = () => {
    if (existingAccountModal) {
      existingAccountModal.hidden = true;
    }
  };

  const resetExistingAccountConfirmation = () => {
    if (confirmExistingAccountInput) confirmExistingAccountInput.value = '0';
    if (confirmedExistingAccountEmailInput) confirmedExistingAccountEmailInput.value = '';
  };

  const isFilled = (selector) => {
    const el = form.querySelector(selector);
    if (!el) return false;
    if (el.type === 'checkbox') return el.checked;

    const v = (el.value || '').trim();
    return v.length > 0 && v !== '0';
  };

  const getValidationState = () => {
    if (!isFilled('#checkout_firstName')) {
      return { valid: false, reason: 'Indique le prénom de la personne qui recevra la commande.' };
    }

    if (!isFilled('#checkout_lastName')) {
      return { valid: false, reason: 'Indique le nom de la personne qui recevra la commande.' };
    }

    if (!isFilled('#checkout_phone')) {
      return { valid: false, reason: 'Indique un numéro de téléphone pour te joindre au moment de la livraison ou de la remise.' };
    }

    if (!isFilled('#checkout_email')) {
      return { valid: false, reason: 'Indique ton adresse e-mail pour recevoir le récapitulatif de commande.' };
    }

    if (!isFilled('#checkout_acceptTerms')) {
      return { valid: false, reason: 'Accepte les conditions avant de valider ta commande.' };
    }

    const deliveryMethodInput = form.querySelector('#checkout_deliveryMethod');
    const deliveryPointSection = form.querySelector('[data-delivery-point-section]');
    const usesDeliveryPoint = deliveryMethodInput && deliveryMethodInput.value === 'DELIVERY_POINT';
    const pointRequired = deliveryPointSection && deliveryPointSection.dataset.pointRequired === '1';

    if (usesDeliveryPoint || pointRequired) {
      const pointInput = form.querySelector('#checkout_deliveryPointId');
      const requestedDateInput = form.querySelector('#checkout_deliveryPointRequestedDate');
      const requestedTimeInput = form.querySelector('#checkout_deliveryPointRequestedTime');

      if (!pointInput || !(pointInput.value || '').trim()) {
        return { valid: false, reason: 'Choisis un point de remise pour continuer.' };
      }

      if (!requestedDateInput || !(requestedDateInput.value || '').trim()) {
        return { valid: false, reason: 'Indique la date à laquelle tu seras au point de remise.' };
      }

      if (!requestedTimeInput || !(requestedTimeInput.value || '').trim()) {
        return { valid: false, reason: 'Choisis un créneau de remise disponible.' };
      }
    } else {
      if (!isFilled('#checkout_address')) {
        return { valid: false, reason: 'Indique l’adresse où le livreur doit te retrouver.' };
      }

      if (!isFilled('#checkout_commune') || !isFilled('#checkout_postalCode')) {
        return { valid: false, reason: 'Choisis une commune livrée pour recalculer les frais.' };
      }
    }

    const sameBilling = form.querySelector('#checkout_useBillingSameAsDelivery');
    if (sameBilling && sameBilling.checked) {
      return { valid: true, reason: '' };
    }

    const billingOk = ['#checkout_billingAddress', '#checkout_billingPostalCode', '#checkout_billingCommune', '#checkout_billingZone'].every(sel => {
      const el = form.querySelector(sel);
      return el && (el.value || '').trim().length > 0;
    });

    return billingOk
      ? { valid: true, reason: '' }
      : { valid: false, reason: 'Confirme l’adresse utilisée pour la facturation.' };
  };

  const isValid = () => getValidationState().valid;

  const formatZoneLabel = (zone) => {
    if (zone === 'PT') return 'Petite-Terre (PT)';
    if (zone === 'GT') return 'Grande-Terre (GT)';
    return zone || 'Choisis une commune livrée.';
  };

  const updateDeliveryCurrentSummary = () => {
    const addressInput = form.querySelector('#checkout_address');
    const communeInput = form.querySelector('#checkout_commune');
    const postalInput = form.querySelector('#checkout_postalCode');
    const localityInput = form.querySelector('#checkout_localityText');
    const zoneInput = form.querySelector('#checkout_zone');
    const instructionsInput = form.querySelector('#checkout_deliveryInstructions');
    const gpsLatInput = form.querySelector('#checkout_gpsLatitude');
    const gpsLngInput = form.querySelector('#checkout_gpsLongitude');
    const gpsAccuracyInput = form.querySelector('#checkout_gpsAccuracyMeters');

    const addressEl = document.querySelector('[data-delivery-current-address]');
    const communeEl = document.querySelector('[data-delivery-current-commune]');
    const localityEl = document.querySelector('[data-delivery-current-locality]');
    const zoneEl = document.querySelector('[data-delivery-current-zone]');
    const instructionsEl = document.querySelector('[data-delivery-current-instructions]');
    const gpsEl = document.querySelector('[data-delivery-current-gps]');

    const communeLabel = communeInput && communeInput.selectedIndex >= 0
      ? (communeInput.options[communeInput.selectedIndex].textContent || '').replace(/\s+—\s+.*$/, '').trim()
      : '';

    const address = addressInput ? (addressInput.value || '').trim() : '';
    const postalCode = postalInput ? (postalInput.value || '').trim() : '';
    const locality = localityInput ? (localityInput.value || '').trim() : '';
    const zone = zoneInput ? (zoneInput.value || '').trim() : '';

    if (addressEl) addressEl.textContent = address || 'Adresse à compléter';
    if (localityEl) localityEl.textContent = locality ? ('Localité : ' + locality) : 'Localité : non renseignée';
    if (communeEl) communeEl.textContent = (postalCode || communeLabel)
      ? ((postalCode ? postalCode + ' ' : '') + (communeLabel || 'Commune à choisir'))
      : 'Commune à choisir';
    if (zoneEl) zoneEl.textContent = formatZoneLabel(zone);
    if (instructionsEl) {
      const instructions = instructionsInput ? (instructionsInput.value || '').trim() : '';
      instructionsEl.textContent = instructions ? 'Instructions : ' + instructions : 'Instructions : non renseignées';
    }

    if (gpsEl) {
      const lat = gpsLatInput ? (gpsLatInput.value || '').trim() : '';
      const lng = gpsLngInput ? (gpsLngInput.value || '').trim() : '';
      const accuracy = gpsAccuracyInput ? (gpsAccuracyInput.value || '').trim() : '';

      gpsEl.replaceChildren();

      const label = document.createElement('span');
      label.className = 'cart-address-gps-label';
      label.textContent = 'GPS :';
      gpsEl.appendChild(label);

      if (lat && lng) {
        const value = document.createElement('span');
        value.className = 'cart-address-gps-value';
        value.textContent = lat + ', ' + lng + (accuracy ? ' (~' + Math.round(parseFloat(accuracy)) + ' m)' : '');
        gpsEl.appendChild(value);
      } else {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'cart-address-gps-inline-btn';
        button.setAttribute('data-open-gps-field', '');
        button.textContent = 'Position GPS';
        gpsEl.appendChild(button);
      }
    }
  };

  const getSelectedDeliveryPointCard = () => {
    const pointInput = form.querySelector('#checkout_deliveryPointId');
    const pointId = pointInput ? (pointInput.value || '').trim() : '';
    return Array.from(form.querySelectorAll('[data-delivery-point-card]')).find((card) => card.dataset.pointId === pointId) || null;
  };

  const updateDeliveryPointCurrentSummary = () => {
    const currentCard = document.querySelector('[data-delivery-point-current-card]');
    if (!currentCard) return;

    const selectedCard = getSelectedDeliveryPointCard();
    const nameEl = currentCard.querySelector('[data-delivery-point-current-name]');
    const addressEl = currentCard.querySelector('[data-delivery-point-current-address]');
    const communeEl = currentCard.querySelector('[data-delivery-point-current-commune]');
    const appointmentEl = currentCard.querySelector('[data-delivery-point-current-appointment]');
    const instructionsEl = currentCard.querySelector('[data-delivery-point-current-instructions]');

    if (!selectedCard) {
      if (nameEl) nameEl.textContent = 'Point de remise à choisir';
      if (addressEl) addressEl.textContent = '';
      if (communeEl) communeEl.textContent = '';
      if (appointmentEl) appointmentEl.textContent = 'Rendez-vous à préciser.';
      if (instructionsEl) instructionsEl.textContent = '';
      return;
    }

    const requestedDateInput = form.querySelector('#checkout_deliveryPointRequestedDate');
    const requestedTimeInput = form.querySelector('#checkout_deliveryPointRequestedTime');
    const customerInstructionsInput = form.querySelector('#checkout_deliveryPointCustomerInstructions');
    const date = requestedDateInput ? (requestedDateInput.value || '').trim() : '';
    const time = requestedTimeInput ? (requestedTimeInput.value || '').trim() : '';
    const selectedSlot = Array.from(form.querySelectorAll('[data-delivery-point-slot-select]')).find((select) => select.value === time && !select.disabled);
    const slotLabel = selectedSlot && selectedSlot.selectedIndex > 0 ? selectedSlot.options[selectedSlot.selectedIndex].textContent : time;
    const publicInstructions = selectedCard.dataset.publicInstructions || '';
    const customerInstructions = customerInstructionsInput ? (customerInstructionsInput.value || '').trim() : '';

    if (nameEl) nameEl.textContent = selectedCard.dataset.pointName || 'Point de remise';
    if (addressEl) addressEl.textContent = selectedCard.dataset.line1 || '';
    if (communeEl) {
      const postal = selectedCard.dataset.postalCode || '';
      const commune = selectedCard.dataset.commune || '';
      communeEl.textContent = (postal ? postal + ' ' : '') + commune;
    }
    if (appointmentEl) appointmentEl.textContent = date && time ? 'Rendez-vous : ' + date + ' à ' + time : 'Rendez-vous à préciser.';
    if (instructionsEl) {
      const parts = [];
      if (publicInstructions) parts.push('Consigne du point : ' + publicInstructions);
      if (customerInstructions) parts.push('Précision client : ' + customerInstructions);
      instructionsEl.textContent = parts.join(' · ');
    }
  };

  const logisticsBox = document.getElementById('checkout-logistics-preview');
  const deliveryFeeUpdateFlash = document.querySelector('[data-delivery-fee-update-flash]');
  let logisticsAbortController = null;
  let cartSyncing = false;
  let logisticsPreviewInitialized = false;
  let lastDeliveryFeeSignature = null;

  const showDeliveryFeeUpdateFlash = () => {
    if (!deliveryFeeUpdateFlash) return;
    deliveryFeeUpdateFlash.hidden = false;
  };

  const hideDeliveryFeeUpdateFlash = () => {
    if (!deliveryFeeUpdateFlash) return;
    deliveryFeeUpdateFlash.hidden = true;
  };

  document.querySelectorAll('[data-dismiss-delivery-fee-update]').forEach((button) => {
    button.addEventListener('click', hideDeliveryFeeUpdateFlash);
  });

  const setText = (selector, value) => {
    const el = logisticsBox ? logisticsBox.querySelector(selector) : null;
    if (el) el.textContent = value || '';
  };

  const setHidden = (selector, hidden) => {
    const el = logisticsBox ? logisticsBox.querySelector(selector) : null;
    if (el) el.hidden = hidden;
  };

  const renderWarnings = (warnings) => {
    const list = logisticsBox ? logisticsBox.querySelector('[data-logistics-warnings]') : null;
    if (!list) return;

    list.innerHTML = '';
    (warnings || []).forEach((warning) => {
      const li = document.createElement('li');
      li.textContent = warning;
      list.appendChild(li);
    });

    list.hidden = !warnings || warnings.length === 0;
  };

  const renderRoutes = (routes) => {
    const wrap = logisticsBox ? logisticsBox.querySelector('[data-logistics-routes-wrap]') : null;
    const list = logisticsBox ? logisticsBox.querySelector('[data-logistics-routes]') : null;
    if (!wrap || !list) return;

    list.innerHTML = '';
    (routes || []).forEach((route) => {
      const li = document.createElement('li');
      const commune = route.sellerCommuneName ? route.sellerCommuneName + ' — ' : '';
      const sellers = route.sellerNamesSummary || (Array.isArray(route.sellerNames) ? route.sellerNames.join(', ') : '') || route.sellerName || 'Vendeur';
      const summary = route.found ? (route.summary || 'trajet détecté') : 'trajet à confirmer';
      li.textContent = commune + sellers + ' : ' + summary;
      list.appendChild(li);
    });

    wrap.hidden = !routes || routes.length === 0;
  };

  const getGpsInputs = () => ({
    gpsStatus: document.querySelector('[data-gps-status]'),
    coordinatesInput: document.getElementById('delivery-gps-coordinates'),
    latInput: form.querySelector('#checkout_gpsLatitude'),
    lngInput: form.querySelector('#checkout_gpsLongitude'),
    accuracyInput: form.querySelector('#checkout_gpsAccuracyMeters')
  });

  const syncGpsCoordinatesInputFromHidden = () => {
    const { coordinatesInput, latInput, lngInput } = getGpsInputs();
    if (!coordinatesInput || !latInput || !lngInput) return;

    const lat = (latInput.value || '').trim();
    const lng = (lngInput.value || '').trim();
    coordinatesInput.value = lat && lng ? lat + ', ' + lng : '';
  };

  const parseGpsCoordinates = (value) => {
    const matches = String(value || '').match(/[-+]?\d+(?:[.,]\d+)?/g) || [];
    if (matches.length < 2) return null;

    const lat = Number(matches[0].replace(',', '.'));
    const lng = Number(matches[1].replace(',', '.'));

    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
    if (lat < -90 || lat > 90 || lng < -180 || lng > 180) return null;

    return {
      lat: lat.toFixed(7),
      lng: lng.toFixed(7)
    };
  };

  const updateGpsStatus = () => {
    const { gpsStatus, latInput, lngInput, accuracyInput } = getGpsInputs();

    if (!gpsStatus || !latInput || !lngInput) return;

    const lat = (latInput.value || '').trim();
    const lng = (lngInput.value || '').trim();
    const accuracy = accuracyInput ? (accuracyInput.value || '').trim() : '';

    gpsStatus.textContent = lat && lng
      ? 'Position GPS enregistrée : ' + lat + ', ' + lng + (accuracy ? ' (~' + Math.round(parseFloat(accuracy)) + ' m)' : '')
      : 'Position GPS non renseignée.';

    updateDeliveryCurrentSummary();
  };

  const renderDeliverySchedule = (schedule) => {
    const boxes = Array.from(document.querySelectorAll('[data-delivery-schedule]'));
    if (boxes.length === 0) return;

    boxes.forEach((box) => {
      const write = (selector, value) => {
        const el = box.querySelector(selector);
        if (el) el.textContent = value || '';
      };

      if (!schedule || schedule.isActive === false) {
        box.hidden = true;
        write('[data-delivery-schedule-title]', '');
        write('[data-delivery-schedule-next]', '');
        write('[data-delivery-schedule-cutoff]', '');
        write('[data-delivery-schedule-confirmation]', '');
        return;
      }

      box.hidden = false;
      write('[data-delivery-schedule-title]', schedule.message || 'Jours de passage selon ta commune.');

      const hasNext = !!schedule.nextDeliveryDateLabel;
      const nextRow = box.querySelector('[data-delivery-schedule-next-row]');
      if (nextRow) nextRow.hidden = !hasNext;
      write('[data-delivery-schedule-next]', schedule.nextDeliveryDateLabel || '');

      const hasCutoff = !!schedule.cutoffLabel;
      const cutoffRow = box.querySelector('[data-delivery-schedule-cutoff-row]');
      if (cutoffRow) cutoffRow.hidden = !hasCutoff;
      write('[data-delivery-schedule-cutoff]', schedule.cutoffLabel || '');
      write('[data-delivery-schedule-confirmation]', schedule.confirmationLabel || 'La date finale est confirmée par Hodina après vérification des vendeurs.');
    });
  };

  const previewNumber = (value) => {
    const number = Number(value || 0);
    return Number.isFinite(number) ? number : 0;
  };

  const previewRoutes = (preview) => {
    const collectionRoutes = Array.isArray(preview.collectionRouteDetails) ? preview.collectionRouteDetails : [];
    const sellerRoutes = Array.isArray(preview.sellerRouteDetails) ? preview.sellerRouteDetails : [];
    return collectionRoutes.concat(sellerRoutes);
  };

  const maxRouteMetric = (preview, key) => previewRoutes(preview).reduce((max, route) => {
    if (!route || typeof route !== 'object') return max;
    return Math.max(max, previewNumber(route[key]));
  }, 0);

  const routeRequiresBarge = (preview) => previewRoutes(preview).some((route) => {
    if (!route || typeof route !== 'object') return false;
    return route.requiresBarge === true || previewNumber(route.bargeHopCount) > 0;
  });

  const buildDeliveryFeeReason = (preview) => {
    const reasons = [];
    const landHopCount = Math.max(previewNumber(preview.landHopCount), maxRouteMetric(preview, 'landHopCount'));
    const bargeHopCount = Math.max(previewNumber(preview.bargeHopCount), maxRouteMetric(preview, 'bargeHopCount'));

    if (landHopCount > 0) {
      reasons.push(landHopCount + ' commune' + (landHopCount > 1 ? 's' : '') + ' traversée' + (landHopCount > 1 ? 's' : ''));
    } else if (previewNumber(preview.collectionPointCount) > 1) {
      reasons.push('plusieurs communes de collecte');
    }

    if (preview.requiresBarge || bargeHopCount > 0 || routeRequiresBarge(preview)) {
      reasons.push('barge');
    }

    return reasons.length ? 'Inclus : ' + reasons.join(' + ') + '.' : '';
  };

  const buildDeliveryFeeSignature = (payload, feeReason) => {
    if (!payload || payload.deliveryFee === null || payload.deliveryFee === undefined) return null;
    return [
      String(payload.deliveryFee),
      String(payload.totalWithDelivery || ''),
      feeReason || ''
    ].join('|');
  };

  const renderLogisticsPreview = (payload, shouldNotifyFeeUpdate = false) => {
    if (!logisticsBox || !payload || !payload.preview) return;

    const preview = payload.preview;
    logisticsBox.classList.toggle('is-barge', !!preview.requiresBarge);
    setText('[data-logistics-message]', preview.message || 'Livraison estimée mise à jour.');

    const hasCommune = !!preview.clientCommuneName;
    setHidden('[data-logistics-commune-row]', !hasCommune);
    setText('[data-logistics-commune]', preview.clientCommuneName || '');
    setText('[data-logistics-territory]', preview.clientTerritory ? '(' + preview.clientTerritory + ')' : '');

    const hasAddress = !preview.addressRequired;
    setHidden('[data-logistics-barge-row]', !hasAddress);
    setText('[data-logistics-barge]', preview.requiresBarge ? 'requise' : 'non détectée');

    const sellerCount = preview.sellerCount || 0;
    setHidden('[data-logistics-seller-row]', sellerCount <= 0);
    setText('[data-logistics-seller-count]', String(sellerCount));

    const collectionPointCount = preview.collectionPointCount || 0;
    setHidden('[data-logistics-collection-row]', collectionPointCount <= 0);
    setText('[data-logistics-collection-count]', String(collectionPointCount));

    const hasLinks = !!preview.totalHopCount && preview.totalHopCount > 0;
    setHidden('[data-logistics-links-row]', !hasLinks);
    setText('[data-logistics-land]', String(preview.landHopCount || 0));
    const hasBargeLinks = !!preview.bargeHopCount && preview.bargeHopCount > 0;
    setHidden('[data-logistics-barge-links-wrap]', !hasBargeLinks);
    setText('[data-logistics-barge-links]', String(preview.bargeHopCount || 0));

    const hasFee = payload.deliveryFee !== null && payload.deliveryFee !== undefined;
    setHidden('[data-logistics-fee-row]', !hasFee);
    setHidden('[data-logistics-total-row]', !hasFee);
    setText('[data-logistics-fee]', payload.deliveryFeeFormatted || '');
    const feeReason = ((payload.deliveryFeeReason || '').trim()) || buildDeliveryFeeReason(preview);
    setHidden('[data-logistics-fee-reason]', !hasFee || feeReason === '');
    setText('[data-logistics-fee-reason]', feeReason);
    setText('[data-logistics-total]', payload.totalWithDeliveryFormatted || '');

    const currentDeliveryFeeSignature = buildDeliveryFeeSignature(payload, feeReason);
    if (logisticsPreviewInitialized && shouldNotifyFeeUpdate && currentDeliveryFeeSignature !== null && currentDeliveryFeeSignature !== lastDeliveryFeeSignature) {
      showDeliveryFeeUpdateFlash();
    }
    if (currentDeliveryFeeSignature !== null) {
      lastDeliveryFeeSignature = currentDeliveryFeeSignature;
    }
    logisticsPreviewInitialized = true;

    renderDeliverySchedule(payload.deliverySchedule || null);

    const mobileTotalEl = document.querySelector('[data-cart-mobile-total]');
    const mobileDeliveryEl = document.querySelector('[data-cart-mobile-delivery]');
    const productsTotalEl = document.querySelector('[data-checkout-products-total]');
    if (mobileTotalEl) {
      mobileTotalEl.textContent = hasFee
        ? (payload.totalWithDeliveryFormatted || '')
        : (productsTotalEl ? productsTotalEl.textContent : '');
    }
    if (mobileDeliveryEl) mobileDeliveryEl.textContent = hasFee ? 'livraison incluse' : 'hors livraison';

    renderRoutes(preview.collectionRouteDetails || preview.sellerRouteDetails || []);
    renderWarnings(preview.warnings || []);
  };

  const refreshLogisticsPreview = (reason = 'auto') => {
    if (!logisticsBox) return;

    const communeInput = form.querySelector('#checkout_commune');
    const postalInput = form.querySelector('#checkout_postalCode');
    const addressInput = form.querySelector('#checkout_address');
    const methodInput = form.querySelector('#checkout_deliveryMethod');
    const pointInput = form.querySelector('#checkout_deliveryPointId');
    const deliveryMethod = methodInput ? (methodInput.value || 'STANDARD') : 'STANDARD';
    const url = logisticsBox.dataset.previewUrl;

    if (!url) return;
    if (deliveryMethod !== 'DELIVERY_POINT' && !communeInput) return;

    if (logisticsAbortController) {
      logisticsAbortController.abort();
    }

    logisticsAbortController = new AbortController();
    setText('[data-logistics-message]', 'Recalcul de la livraison en cours…');

    const body = new URLSearchParams();
    body.set('deliveryMethod', deliveryMethod);
    body.set('deliveryPointId', pointInput ? (pointInput.value || '') : '');
    body.set('postalCode', postalInput ? (postalInput.value || '') : '');
    body.set('commune', communeInput ? (communeInput.value || '') : '');
    body.set('address', addressInput ? (addressInput.value || '') : '');

    fetch(url, {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
      },
      body,
      signal: logisticsAbortController.signal
    })
      .then((response) => response.json().then((payload) => ({ response, payload })))
      .then(({ response, payload }) => {
        if (!response.ok || payload.ok === false) {
          setText('[data-logistics-message]', payload.message || 'Impossible de recalculer la livraison pour cette commune.');
          setHidden('[data-logistics-fee-row]', true);
          setHidden('[data-logistics-total-row]', true);
          const mobileDeliveryEl = document.querySelector('[data-cart-mobile-delivery]');
          const mobileTotalEl = document.querySelector('[data-cart-mobile-total]');
          const productsTotalEl = document.querySelector('[data-checkout-products-total]');
          if (mobileDeliveryEl) mobileDeliveryEl.textContent = 'livraison à confirmer';
          if (mobileTotalEl && productsTotalEl) mobileTotalEl.textContent = productsTotalEl.textContent;
          renderWarnings([]);
          renderRoutes([]);
          renderDeliverySchedule(null);
          return;
        }

        renderLogisticsPreview(payload, reason === 'delivery-address' || reason === 'delivery-point' || reason === 'delivery-method');
      })
      .catch((error) => {
        if (error && error.name === 'AbortError') return;
        setText('[data-logistics-message]', 'Le recalcul de livraison a échoué. Réessaie ou valide : le serveur recalculera quand même à la commande.');
        renderDeliverySchedule(null);
        const mobileDeliveryEl = document.querySelector('[data-cart-mobile-delivery]');
        if (mobileDeliveryEl) mobileDeliveryEl.textContent = 'livraison à confirmer';
      });
  };

  const getDeliveryPointElements = () => ({
    methodInput: form.querySelector('#checkout_deliveryMethod'),
    pointInput: form.querySelector('#checkout_deliveryPointId'),
    windowInput: form.querySelector('#checkout_deliveryPointTimeWindowId'),
    requestedDateInput: form.querySelector('#checkout_deliveryPointRequestedDate'),
    requestedTimeInput: form.querySelector('#checkout_deliveryPointRequestedTime'),
    slotSelects: Array.from(form.querySelectorAll('[data-delivery-point-slot-select]')),
    slotHelps: Array.from(form.querySelectorAll('[data-delivery-point-slot-help]')),
    section: form.querySelector('[data-delivery-point-section]'),
    modePanel: form.querySelector('[data-delivery-point-mode-panel]'),
    cards: Array.from(form.querySelectorAll('[data-delivery-point-card]')),
    methodButtons: Array.from(form.querySelectorAll('[data-delivery-method]')),
    windowLists: Array.from(form.querySelectorAll('[data-delivery-point-window-list]'))
  });


  const formatSlotMinutes = (minutes) => {
    const h = Math.floor(minutes / 60).toString().padStart(2, '0');
    const m = (minutes % 60).toString().padStart(2, '0');
    return h + ':' + m;
  };

  const timeToMinutes = (value) => {
    const parts = String(value || '').split(':');
    if (parts.length < 2) return null;
    const h = Number.parseInt(parts[0], 10);
    const m = Number.parseInt(parts[1], 10);
    if (!Number.isFinite(h) || !Number.isFinite(m)) return null;
    return h * 60 + m;
  };

  const weekdayFromDateValue = (value) => {
    const match = String(value || '').match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!match) return null;
    const utcDay = new Date(Date.UTC(Number(match[1]), Number(match[2]) - 1, Number(match[3]))).getUTCDay();
    return utcDay === 0 ? 7 : utcDay;
  };

  const buildDeliveryPointSlots = () => {
    const { pointInput, requestedDateInput, windowLists } = getDeliveryPointElements();
    const pointId = pointInput ? (pointInput.value || '').trim() : '';
    const weekday = requestedDateInput ? weekdayFromDateValue(requestedDateInput.value || '') : null;

    if (!pointId || weekday === null) {
      return [];
    }

    const list = windowLists.find((candidate) => candidate.dataset.pointId === pointId);
    if (!list) return [];

    const slots = [];
    Array.from(list.querySelectorAll('li')).forEach((item) => {
      const windowWeekdayRaw = (item.dataset.windowWeekday || '').trim();
      const windowWeekday = windowWeekdayRaw === '' ? null : Number.parseInt(windowWeekdayRaw, 10);
      if (windowWeekday !== null && windowWeekday !== weekday) {
        return;
      }

      const start = timeToMinutes(item.dataset.windowStart || '');
      const end = timeToMinutes(item.dataset.windowEnd || '');
      const windowId = item.dataset.windowId || '';
      const windowLabel = item.dataset.windowLabel || item.textContent.trim() || 'Créneau';
      if (start === null || end === null || end <= start) {
        return;
      }

      for (let minute = start; minute + 30 <= end; minute += 30) {
        const startLabel = formatSlotMinutes(minute);
        const endLabel = formatSlotMinutes(minute + 30);
        slots.push({
          value: startLabel,
          label: startLabel + ' – ' + endLabel,
          windowId,
          windowLabel,
          sort: minute
        });
      }
    });

    slots.sort((left, right) => {
      if (left.sort === right.sort) {
        return left.windowLabel.localeCompare(right.windowLabel);
      }
      return left.sort - right.sort;
    });

    return slots;
  };

  const refreshDeliveryPointSlots = (clearSelection = false) => {
    const { pointInput, requestedDateInput, requestedTimeInput, windowInput, slotSelects, slotHelps } = getDeliveryPointElements();
    const pointId = pointInput ? (pointInput.value || '').trim() : '';
    const dateValue = requestedDateInput ? (requestedDateInput.value || '').trim() : '';
    const existingTime = !clearSelection && requestedTimeInput ? (requestedTimeInput.value || '').trim() : '';
    const existingWindow = !clearSelection && windowInput ? (windowInput.value || '').trim() : '';
    const slots = buildDeliveryPointSlots();

    let placeholderText = 'Choisis d’abord un point de remise';
    let helpText = 'Choisis un point, puis une date pour afficher les créneaux disponibles.';

    if (pointId && !dateValue) {
      placeholderText = 'Choisis d’abord une date';
      helpText = 'Après avoir choisi une date, Hodina affichera les créneaux de 30 minutes disponibles.';
    } else if (!pointId && dateValue) {
      placeholderText = 'Choisis d’abord un point de remise';
      helpText = 'Choisis le point de remise pour voir ses créneaux disponibles.';
    } else if (pointId && dateValue && slots.length === 0) {
      placeholderText = 'Aucun créneau disponible ce jour-là';
      helpText = 'Choisis une autre date ou un autre point de remise.';
    } else if (slots.length > 0) {
      placeholderText = 'Choisis un créneau';
      helpText = 'Créneaux de 30 minutes calculés à partir des horaires du point de remise.';
    }

    if (clearSelection) {
      if (requestedTimeInput) requestedTimeInput.value = '';
      if (windowInput) windowInput.value = '';
    }

    slotSelects.forEach((select) => {
      select.innerHTML = '';

      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = placeholderText;
      select.appendChild(placeholder);

      slots.forEach((slot) => {
        const option = document.createElement('option');
        option.value = slot.value;
        option.dataset.windowId = slot.windowId;
        option.textContent = slot.label;
        if (existingTime === slot.value && (!existingWindow || existingWindow === slot.windowId)) {
          option.selected = true;
          if (requestedTimeInput) requestedTimeInput.value = slot.value;
          if (windowInput) windowInput.value = slot.windowId;
        }
        select.appendChild(option);
      });

      select.disabled = slots.length === 0;
      select.setAttribute('aria-disabled', slots.length === 0 ? 'true' : 'false');
      if (slots.length > 0 && !select.value && requestedTimeInput && requestedTimeInput.value) {
        requestedTimeInput.value = '';
        if (windowInput) windowInput.value = '';
      }
    });

    slotHelps.forEach((help) => {
      help.textContent = helpText;
    });
  };

  const applyDeliveryPointSlotSelect = (select) => {
    const { requestedTimeInput, windowInput } = getDeliveryPointElements();
    const option = select.options[select.selectedIndex];
    if (requestedTimeInput) requestedTimeInput.value = select.value || '';
    if (windowInput) windowInput.value = option ? (option.dataset.windowId || '') : '';
    updateDeliveryPointCurrentSummary();
    refresh();
  };

  const setDeliveryMethod = (method) => {
    const { methodInput, section, modePanel, methodButtons } = getDeliveryPointElements();
    const pointRequired = section && section.dataset.pointRequired === '1';
    const normalized = pointRequired ? 'DELIVERY_POINT' : (method === 'DELIVERY_POINT' ? 'DELIVERY_POINT' : 'STANDARD');

    if (methodInput) methodInput.value = normalized;
    methodButtons.forEach((button) => {
      button.classList.toggle('is-selected', button.dataset.deliveryMethod === normalized);
      button.setAttribute('aria-pressed', button.dataset.deliveryMethod === normalized ? 'true' : 'false');
    });

    const usesDeliveryPoint = normalized === 'DELIVERY_POINT';
    const standardDeliveryBlock = document.querySelector('[data-standard-delivery-block]');
    const standardDeliverySummary = document.querySelector('[data-standard-delivery-summary]');
    const standardDeliveryPicker = document.querySelector('[data-standard-delivery-picker]');
    const deliveryPointSummary = document.querySelector('[data-delivery-point-current-card]');

    if (standardDeliveryBlock) standardDeliveryBlock.hidden = usesDeliveryPoint;
    if (standardDeliverySummary) standardDeliverySummary.hidden = usesDeliveryPoint;
    if (standardDeliveryPicker) standardDeliveryPicker.hidden = usesDeliveryPoint;
    if (deliveryPointSummary) deliveryPointSummary.hidden = !usesDeliveryPoint;
    if (modePanel) modePanel.hidden = !usesDeliveryPoint;

    updateDeliveryPointCurrentSummary();
  };

  const refreshDeliveryPointWindows = (clearSlotSelection = false) => {
    const { pointInput, windowInput, windowLists, requestedTimeInput } = getDeliveryPointElements();
    if (!pointInput) return;

    const pointId = (pointInput.value || '').trim();
    windowLists.forEach((list) => {
      list.hidden = list.dataset.pointId !== pointId;
    });

    if (clearSlotSelection) {
      if (windowInput) windowInput.value = '';
      if (requestedTimeInput) requestedTimeInput.value = '';
    }

    refreshDeliveryPointSlots(clearSlotSelection);
  };

  const applyDeliveryPointCard = (card) => {
    if (!card) return;

    const { pointInput, cards } = getDeliveryPointElements();

    setDeliveryMethod('DELIVERY_POINT');
    if (pointInput) pointInput.value = card.dataset.pointId || '';

    cards.forEach((candidate) => {
      const selected = candidate === card;
      candidate.classList.toggle('is-selected', selected);
      candidate.setAttribute('aria-pressed', selected ? 'true' : 'false');
    });

    refreshDeliveryPointWindows(true);
    updateDeliveryPointCurrentSummary();
    refreshLogisticsPreview('delivery-point');
    refresh();
  };

  const getSelectedCommuneOption = () => {
    const communeInput = form.querySelector('#checkout_commune');

    if (!communeInput || communeInput.selectedIndex < 0) {
      return null;
    }

    const selectedOption = communeInput.options[communeInput.selectedIndex];

    return selectedOption && selectedOption.value ? selectedOption : null;
  };

  const applyPostalCodeFilter = (options = {}) => {
    const autoSelectSingle = options.autoSelectSingle !== false;
    const communeInput = form.querySelector('#checkout_commune');
    const postalInput = form.querySelector('#checkout_postalCode');

    if (!communeInput || !postalInput) {
      return;
    }

    const postalCode = (postalInput.value || '').trim();
    const compatibleOptions = [];

    Array.from(communeInput.options).forEach((option) => {
      if (!option.value) {
        option.disabled = false;
        option.hidden = false;
        return;
      }

      const compatible = !postalCode || (option.dataset.postalCode || '') === postalCode;
      option.disabled = !compatible;
      option.hidden = !compatible;

      if (compatible) {
        compatibleOptions.push(option);
      }
    });

    const selectedOption = getSelectedCommuneOption();
    if (selectedOption && selectedOption.disabled) {
      communeInput.value = '';
    }

    if (postalCode && autoSelectSingle && !communeInput.value && compatibleOptions.length === 1) {
      communeInput.value = compatibleOptions[0].value;
    }
  };

  const applyCommuneMetadata = (options = {}) => {
    const syncPostalCode = options.syncPostalCode !== false;
    const communeInput = form.querySelector('#checkout_commune');
    const postalInput = form.querySelector('#checkout_postalCode');
    const localityInput = form.querySelector('#checkout_localityText');
    const zoneInput = form.querySelector('#checkout_zone');
    const zonePreview = document.getElementById('checkout-zone-preview');

    const selectedOption = getSelectedCommuneOption();
    const postalCode = selectedOption ? (selectedOption.dataset.postalCode || '') : '';
    const zone = selectedOption ? (selectedOption.dataset.zone || '') : '';

    if (postalInput && syncPostalCode && postalCode) {
      postalInput.value = postalCode;
      applyPostalCodeFilter({ autoSelectSingle: false });
    }

    if (zoneInput) zoneInput.value = zone;
    if (zonePreview) zonePreview.textContent = formatZoneLabel(zone);
    updateDeliveryCurrentSummary();
  };

  const refresh = () => {
    const sameBilling = form.querySelector('#checkout_useBillingSameAsDelivery');
    const billingFields = document.getElementById('checkout-billing-fields');
    if (sameBilling && billingFields) {
      billingFields.style.display = sameBilling.checked ? 'none' : 'block';
    }

    const validationState = getValidationState();
    const visuallyDisabled = cartSyncing || !validationState.valid;
    submitButtons.forEach((button) => {
      button.disabled = cartSyncing;
      button.setAttribute('aria-disabled', visuallyDisabled ? 'true' : 'false');
      button.classList.toggle('is-disabled', visuallyDisabled);
    });

    const helper = document.querySelector('[data-checkout-submit-helper]');
    if (helper) {
      helper.textContent = visuallyDisabled
        ? (cartSyncing ? 'Recalcul du panier en cours...' : 'Complète les informations obligatoires pour valider ta commande.')
        : 'Toutes les informations obligatoires sont complètes. Tu peux valider ta commande.';
    }

    const clientAlert = document.querySelector('[data-checkout-client-alert]');
    const clientAlertMessage = document.querySelector('[data-checkout-client-alert-message]');
    if (clientAlert && clientAlertMessage) {
      const showClientAlert = checkoutSubmitAttempted && !cartSyncing && !validationState.valid;
      clientAlert.hidden = !showClientAlert;
      if (showClientAlert) {
        clientAlertMessage.textContent = validationState.reason;
      }
    }
  };

  window.addEventListener('hodina:cart-sync-started', () => {
    cartSyncing = true;
    refresh();
  });

  window.addEventListener('hodina:cart-synced', () => {
    cartSyncing = false;
    refreshLogisticsPreview();
    refresh();
  });

  window.addEventListener('hodina:cart-sync-failed', () => {
    cartSyncing = false;
    refresh();
  });


  if (existingAccountModal) {
    checkoutSubmitAttempted = true;
    refresh();
    window.setTimeout(() => {
      existingAccountModal.querySelector('[data-existing-account-confirm]')?.focus();
    }, 60);
  }

  if (existingAccountConfirmButton) {
    existingAccountConfirmButton.addEventListener('click', () => {
      const emailToConfirm = (existingAccountModal?.dataset.existingAccountEmail || emailInput?.value || '').trim().toLowerCase();
      if (confirmExistingAccountInput) confirmExistingAccountInput.value = '1';
      if (confirmedExistingAccountEmailInput) confirmedExistingAccountEmailInput.value = emailToConfirm;
      hideExistingAccountModal();

      if (form.requestSubmit) {
        form.requestSubmit(submitButtons[0]);
      } else {
        form.submit();
      }
    });
  }

  existingAccountEditButtons.forEach((button) => {
    button.addEventListener('click', () => {
      resetExistingAccountConfirmation();
      hideExistingAccountModal();
      if (emailInput) {
        emailInput.focus({ preventScroll: true });
        emailInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  });

  if (emailInput) {
    emailInput.addEventListener('input', resetExistingAccountConfirmation);
  }

  submitButtons.forEach((button) => {
    button.addEventListener('click', (event) => {
      const validationState = getValidationState();
      if (cartSyncing || !validationState.valid) {
        event.preventDefault();
        event.stopPropagation();
        showClientValidationAlert();
      }
    });
  });

  form.addEventListener('submit', (event) => {
    const submitter = event.submitter || null;
    if (submitter && !submitter.matches('[data-checkout-submit]')) {
      return;
    }

    const validationState = getValidationState();
    if (cartSyncing || !validationState.valid) {
      event.preventDefault();
      showClientValidationAlert();
    }
  });


  const normalizeLocalityQuery = (value) => (value || '')
    .toString()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .trim();

  const getLocalityOptions = () => {
    const datalist = document.getElementById('checkout-address-locality-suggestions');
    if (!datalist) return [];

    return Array.from(datalist.options).map((option) => {
      const name = option.value || '';
      const commune = option.dataset.commune || '';
      const postalCode = option.dataset.postalCode || '';

      return {
        name,
        commune,
        postalCode,
        localityId: option.dataset.localityId || '',
        label: option.textContent || (commune ? `${name} — ${commune}` : name),
        search: normalizeLocalityQuery(`${name} ${commune} ${postalCode}`),
      };
    }).filter((option) => option.name !== '');
  };

  const hideLocalitySuggestions = (input) => {
    const container = input.closest('.client-form-field')?.querySelector('[data-address-locality-suggestions]') || null;
    if (!container) return;

    container.hidden = true;
    container.innerHTML = '';
  };

  const applyLocalitySuggestion = (input, option) => {
    input.value = option.name;
    syncAddressLocalityFromText(input);
    hideLocalitySuggestions(input);
    updateDeliveryCurrentSummary();
    refresh();
    refreshLogisticsPreview('delivery-address');
  };

  const renderLocalitySuggestions = (input) => {
    const container = input.closest('.client-form-field')?.querySelector('[data-address-locality-suggestions]') || null;
    if (!container) return;

    const query = normalizeLocalityQuery(input.value || '');
    if (query.length < 2) {
      hideLocalitySuggestions(input);
      return;
    }

    const suggestions = getLocalityOptions()
      .filter((option) => option.search.includes(query))
      .slice(0, 7);

    if (suggestions.length === 0) {
      hideLocalitySuggestions(input);
      return;
    }

    container.innerHTML = '';
    suggestions.forEach((option) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'address-locality-suggestion-button';
      button.innerHTML = `<strong>${option.name}</strong><span class="muted small">${option.commune ? option.commune + ' · ' : ''}${option.postalCode}</span>`;
      button.addEventListener('mousedown', (event) => event.preventDefault());
      button.addEventListener('click', () => applyLocalitySuggestion(input, option));
      container.appendChild(button);
    });

    container.hidden = false;
  };

  const syncAddressLocalityFromText = (input = null) => {
    const localityTextInput = input || form.querySelector('[data-address-locality-text]') || form.querySelector('#checkout_localityText');
    const localityIdInput = form.querySelector('#checkout_addressLocalityId');

    if (!localityTextInput || !localityIdInput) {
      return;
    }

    const value = normalizeLocalityQuery(localityTextInput.value || '');
    const matchingOption = getLocalityOptions().find((option) => normalizeLocalityQuery(option.name) === value) || null;

    if (!matchingOption) {
      localityIdInput.value = '';
      return;
    }

    localityIdInput.value = matchingOption.localityId || '';

    const postalCode = matchingOption.postalCode || '';
    const commune = matchingOption.commune || '';
    const postalInput = form.querySelector('#checkout_postalCode');
    const communeInput = form.querySelector('#checkout_commune');

    if (postalInput && postalCode) {
      postalInput.value = postalCode;
      applyPostalCodeFilter({ autoSelectSingle: false });
    }

    if (communeInput && commune) {
      communeInput.value = commune;
      applyCommuneMetadata({ syncPostalCode: true });
    }
  };

  form.addEventListener('input', (event) => {
    if (event.target && ['checkout_billingAddress', 'checkout_billingPostalCode', 'checkout_billingCommune', 'checkout_billingZone'].includes(event.target.id)) {
      setBillingSameAsDelivery(false);
    }

    if (event.target && event.target.matches('[data-address-locality-text]')) {
      renderLocalitySuggestions(event.target);
      syncAddressLocalityFromText(event.target);
    }

    updateDeliveryCurrentSummary();
    updateBillingCurrentSummary();
    refresh();
  });
  form.addEventListener('change', (event) => {
    if (event.target && ['checkout_billingAddress', 'checkout_billingPostalCode', 'checkout_billingCommune', 'checkout_billingZone'].includes(event.target.id)) {
      setBillingSameAsDelivery(false);
      updateBillingCurrentSummary();
    }

    if (event.target && event.target.matches('[data-address-locality-text]')) {
      syncAddressLocalityFromText(event.target);
      refreshLogisticsPreview('delivery-address');
    }

    if (event.target && event.target.id === 'checkout_postalCode') {
      applyPostalCodeFilter({ autoSelectSingle: true });
      applyCommuneMetadata({ syncPostalCode: false });
      refreshLogisticsPreview('delivery-address');
    }

    if (event.target && event.target.id === 'checkout_commune') {
      applyCommuneMetadata();
      refreshLogisticsPreview('delivery-address');
    }

    refresh();
  });

  const openDetails = (picker) => {
    if (!picker) return;
    picker.classList.add('is-open');
    picker.setAttribute('aria-hidden', 'false');
    document.body.classList.add('address-picker-open');

    const panel = picker.querySelector('.address-picker-panel');
    if (panel && panel.focus) {
      window.setTimeout(() => panel.focus(), 30);
    }
  };

  const closeAddressPicker = (picker) => {
    if (!picker) return;
    picker.classList.remove('is-open');
    picker.setAttribute('aria-hidden', 'true');

    if (!document.querySelector('.address-picker-sheet.is-open')) {
      document.body.classList.remove('address-picker-open');
    }
  };

  const updateBillingCurrentSummary = () => {
    const billingAddressInput = form.querySelector('#checkout_billingAddress');
    const billingPostalInput = form.querySelector('#checkout_billingPostalCode');
    const billingCommuneInput = form.querySelector('#checkout_billingCommune');
    const billingAddressEl = document.querySelector('[data-billing-current-address]');
    const billingCommuneEl = document.querySelector('[data-billing-current-commune]');

    const address = billingAddressInput ? (billingAddressInput.value || '').trim() : '';
    const postalCode = billingPostalInput ? (billingPostalInput.value || '').trim() : '';
    const commune = billingCommuneInput ? (billingCommuneInput.value || '').trim() : '';

    if (billingAddressEl) billingAddressEl.textContent = address || 'Adresse de facturation à compléter';
    if (billingCommuneEl) billingCommuneEl.textContent = (postalCode || commune)
      ? ((postalCode ? postalCode + ' ' : '') + commune)
      : '';
  };

  const setBillingSameAsDelivery = (value) => {
    const sameBilling = form.querySelector('#checkout_useBillingSameAsDelivery');
    if (sameBilling) sameBilling.checked = !!value;
  };

  const clearAddressSelection = (selector) => {
    document.querySelectorAll(selector).forEach((card) => {
      card.classList.remove('is-selected');
      card.setAttribute('aria-pressed', 'false');
    });
  };

  const markAddressSelected = (card, selector) => {
    clearAddressSelection(selector);

    if (!card || !card.classList) return;

    card.classList.add('is-selected');
    card.setAttribute('aria-pressed', 'true');
  };

  const applySavedAddress = (sourceEl) => {
    const btnAddr = sourceEl.closest ? (sourceEl.closest('[data-address-card="delivery"]') || sourceEl) : sourceEl;
    const addressInput = document.querySelector('#checkout_address');
    const communeInput = document.querySelector('#checkout_commune');
    const postalInput = document.querySelector('#checkout_postalCode');
    const localityIdInput = document.querySelector('#checkout_addressLocalityId');
    const localityTextInput = document.querySelector('#checkout_localityText');
    const existingInput = document.querySelector('#checkout_existingAddressId');
    const instructionsInput = document.querySelector('#checkout_deliveryInstructions');

    const gpsLatInput = document.querySelector('#checkout_gpsLatitude');
    const gpsLngInput = document.querySelector('#checkout_gpsLongitude');
    const gpsAccuracyInput = document.querySelector('#checkout_gpsAccuracyMeters');

    if(addressInput) addressInput.value = btnAddr.dataset.line1 || '';
    if(postalInput) postalInput.value = btnAddr.dataset.postalCode || '';
    if(communeInput) communeInput.value = btnAddr.dataset.commune || '';
    if(localityIdInput) localityIdInput.value = btnAddr.dataset.localityId || '';
    if(localityTextInput) localityTextInput.value = btnAddr.dataset.localityText || '';
    if(existingInput) existingInput.value = btnAddr.dataset.addressId || '';
    if(instructionsInput) instructionsInput.value = btnAddr.dataset.deliveryInstructions || '';
    if(gpsLatInput) gpsLatInput.value = btnAddr.dataset.gpsLatitude || '';
    if(gpsLngInput) gpsLngInput.value = btnAddr.dataset.gpsLongitude || '';
    if(gpsAccuracyInput) gpsAccuracyInput.value = btnAddr.dataset.gpsAccuracy || '';
    syncGpsCoordinatesInputFromHidden();

    markAddressSelected(btnAddr, '[data-address-card="delivery"]');

    applyPostalCodeFilter({ autoSelectSingle: false });
    applyCommuneMetadata();
    updateGpsStatus();
    refreshLogisticsPreview('delivery-address');
    refresh();
  };

  const applyBillingAddress = (sourceEl) => {
    const card = sourceEl.closest ? (sourceEl.closest('[data-address-card="billing"]') || sourceEl) : sourceEl;
    const existingInput = document.querySelector('#checkout_billingExistingAddressId');
    const billingAddressInput = document.querySelector('#checkout_billingAddress');
    const billingPostalInput = document.querySelector('#checkout_billingPostalCode');
    const billingCommuneInput = document.querySelector('#checkout_billingCommune');
    const billingZoneInput = document.querySelector('#checkout_billingZone');

    if(existingInput) existingInput.value = card.dataset.billingAddressId || '';
    if(billingAddressInput) billingAddressInput.value = card.dataset.billingLine1 || '';
    if(billingPostalInput) billingPostalInput.value = card.dataset.billingPostalCode || '';
    if(billingCommuneInput) billingCommuneInput.value = card.dataset.billingCommune || '';
    if(billingZoneInput) billingZoneInput.value = card.dataset.billingZone || 'AUTRE';

    markAddressSelected(card, '[data-address-card="billing"]');

    setBillingSameAsDelivery(false);
    updateBillingCurrentSummary();
    refresh();
  };

  getDeliveryPointElements().methodButtons.forEach((button) => {
    button.addEventListener('click', () => {
      setDeliveryMethod(button.dataset.deliveryMethod || 'STANDARD');
      if (button.dataset.deliveryMethod === 'DELIVERY_POINT') {
        const { pointInput, cards } = getDeliveryPointElements();
        const selected = cards.find((card) => card.dataset.pointId === (pointInput ? pointInput.value : '')) || cards[0];
        applyDeliveryPointCard(selected);
      } else {
        updateDeliveryCurrentSummary();
        refreshLogisticsPreview('delivery-method');
        refresh();
      }
    });
  });

  getDeliveryPointElements().cards.forEach((card) => {
    card.addEventListener('click', () => applyDeliveryPointCard(card));
  });

  document.querySelectorAll('[data-address-card="delivery"]').forEach(card => {
    card.addEventListener('click', (event) => {
      if (event.target && event.target.closest('button[type="submit"]')) return;
      applySavedAddress(card);
    });

    card.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      applySavedAddress(card);
    });
  });

  document.querySelectorAll('[data-edit-delivery-address]').forEach(editBtn => {
    editBtn.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      applySavedAddress(editBtn);
      openDetails(document.getElementById('checkout-address-details'));
      const addressInput = document.querySelector('#checkout_address');
      if (addressInput) addressInput.focus();
    });
  });

  document.querySelectorAll('[data-address-card="billing"]').forEach(card => {
    card.addEventListener('click', (event) => {
      if (event.target && event.target.closest('button[type="submit"]')) return;
      applyBillingAddress(card);
    });

    card.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      applyBillingAddress(card);
    });
  });

  document.querySelectorAll('[data-edit-billing-address]').forEach(editBtn => {
    editBtn.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      applyBillingAddress(editBtn);
      openDetails(document.getElementById('checkout-billing-details'));
      const billingAddressInput = document.querySelector('#checkout_billingAddress');
      if (billingAddressInput) billingAddressInput.focus();
    });
  });

  document.querySelectorAll('[data-open-address-picker]').forEach((button) => {
    button.addEventListener('click', () => {
      const pickerId = button.getAttribute('data-open-address-picker');
      openDetails(document.getElementById(pickerId));
    });
  });

  document.querySelectorAll('[data-use-address-picker]').forEach((button) => {
    button.addEventListener('click', (event) => {
      event.preventDefault();

      if (button.getAttribute('data-use-address-picker') === 'delivery') {
        applyCommuneMetadata();
        syncGpsCoordinatesInputFromHidden();
        updateGpsStatus();
        updateDeliveryCurrentSummary();
        refreshLogisticsPreview('delivery-address');
      }

      if (button.getAttribute('data-use-address-picker') === 'billing') {
        setBillingSameAsDelivery(false);
        updateBillingCurrentSummary();
      }

      refresh();
      closeAddressPicker(button.closest('.address-picker-sheet'));
    });
  });

  document.querySelectorAll('[data-close-address-picker]').forEach((button) => {
    button.addEventListener('click', (event) => {
      event.preventDefault();
      closeAddressPicker(button.closest('.address-picker-sheet'));
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    document.querySelectorAll('.address-picker-sheet.is-open').forEach(closeAddressPicker);
  });

  document.querySelectorAll('.address-picker-sheet.is-open').forEach((picker) => {
    document.body.classList.add('address-picker-open');
    picker.setAttribute('aria-hidden', 'false');
  });

  const editDeliveryBtn = document.getElementById('edit-delivery-address');
  if(editDeliveryBtn){
    editDeliveryBtn.addEventListener('click', () => {
      openDetails(document.getElementById('checkout-address-details'));
    });
  }

  const editBillingBtn = document.getElementById('edit-billing-address');
  if(editBillingBtn){
    editBillingBtn.addEventListener('click', () => {
      openDetails(document.getElementById('checkout-billing-details'));
      setBillingSameAsDelivery(false);
      updateBillingCurrentSummary();
      refresh();
    });
  }

  const newAddressBtn = document.getElementById('use-new-address');
  if(newAddressBtn){
    newAddressBtn.addEventListener('click', () => {
      const addressInput = document.querySelector('#checkout_address');
      const existingInput = document.querySelector('#checkout_existingAddressId');
      const communeInput = document.querySelector('#checkout_commune');
      const postalInput = document.querySelector('#checkout_postalCode');
      const instructionsInput = document.querySelector('#checkout_deliveryInstructions');

      if(existingInput) existingInput.value = '';
      if(addressInput) {
        addressInput.value = '';
        addressInput.focus();
      }
      if(postalInput) {
          postalInput.value = '';
      }
      if(communeInput) {
          communeInput.value = '';
      }
      if(instructionsInput) instructionsInput.value = '';

      const gpsLatInput = document.querySelector('#checkout_gpsLatitude');
      const gpsLngInput = document.querySelector('#checkout_gpsLongitude');
      const gpsAccuracyInput = document.querySelector('#checkout_gpsAccuracyMeters');
      if(gpsLatInput) gpsLatInput.value = '';
      if(gpsLngInput) gpsLngInput.value = '';
      if(gpsAccuracyInput) gpsAccuracyInput.value = '';
      syncGpsCoordinatesInputFromHidden();

      applyPostalCodeFilter({ autoSelectSingle: false });
      applyCommuneMetadata();
      updateGpsStatus();
      refreshLogisticsPreview('delivery-address');
      clearAddressSelection('[data-address-card="delivery"]');
      refresh();
    });
  }

  const newBillingAddressBtn = document.getElementById('use-new-billing-address');
  if(newBillingAddressBtn){
    newBillingAddressBtn.addEventListener('click', () => {
      const existingInput = document.querySelector('#checkout_billingExistingAddressId');
      const billingAddressInput = document.querySelector('#checkout_billingAddress');
      const billingPostalInput = document.querySelector('#checkout_billingPostalCode');
      const billingCommuneInput = document.querySelector('#checkout_billingCommune');
      const billingZoneInput = document.querySelector('#checkout_billingZone');

      if(existingInput) existingInput.value = '';
      if(billingAddressInput) {
        billingAddressInput.value = '';
        billingAddressInput.focus();
      }
      if(billingPostalInput) billingPostalInput.value = '';
      if(billingCommuneInput) billingCommuneInput.value = '';
      if(billingZoneInput) billingZoneInput.value = 'AUTRE';
      setBillingSameAsDelivery(false);
      updateBillingCurrentSummary();
      clearAddressSelection('[data-address-card="billing"]');
      refresh();
    });
  }

  const existingInput = document.querySelector('#checkout_existingAddressId');
  if(existingInput && existingInput.value){
    const selected = document.querySelector(`[data-address-card="delivery"][data-address-id="${existingInput.value}"]`);
    if(selected) markAddressSelected(selected, '[data-address-card="delivery"]');
  }

  const billingExistingInput = document.querySelector('#checkout_billingExistingAddressId');
  if(billingExistingInput && billingExistingInput.value){
    const selectedBilling = document.querySelector(`[data-address-card="billing"][data-billing-address-id="${billingExistingInput.value}"]`);
    if(selectedBilling) markAddressSelected(selectedBilling, '[data-address-card="billing"]');
  }

  updateBillingCurrentSummary();
  const gpsCoordinatesInput = document.getElementById('delivery-gps-coordinates');
  if (gpsCoordinatesInput) {
    gpsCoordinatesInput.addEventListener('input', () => {
      const { gpsStatus, latInput, lngInput, accuracyInput } = getGpsInputs();
      const rawValue = gpsCoordinatesInput.value.trim();

      if (!latInput || !lngInput) return;

      if (!rawValue) {
        latInput.value = '';
        lngInput.value = '';
        if (accuracyInput) accuracyInput.value = '';
        updateGpsStatus();
        refresh();
        return;
      }

      const coordinates = parseGpsCoordinates(rawValue);
      if (!coordinates) {
        if (gpsStatus) gpsStatus.textContent = 'Format GPS invalide. Exemple : -12.7806000, 45.2278000';
        return;
      }

      latInput.value = coordinates.lat;
      lngInput.value = coordinates.lng;
      if (accuracyInput) accuracyInput.value = '';
      updateGpsStatus();
      refresh();
    });
  }

  const useLocationBtn = document.getElementById('use-current-location');
  if (useLocationBtn) {
    useLocationBtn.addEventListener('click', () => {
      const { gpsStatus, latInput, lngInput, accuracyInput } = getGpsInputs();

      if (!navigator.geolocation || !latInput || !lngInput) {
        if (gpsStatus) gpsStatus.textContent = 'La géolocalisation n’est pas disponible sur ce navigateur.';
        return;
      }

      if (gpsStatus) gpsStatus.textContent = 'Recherche de ta position GPS...';

      navigator.geolocation.getCurrentPosition((position) => {
        latInput.value = Number(position.coords.latitude).toFixed(7);
        lngInput.value = Number(position.coords.longitude).toFixed(7);
        if (accuracyInput && position.coords.accuracy !== null && position.coords.accuracy !== undefined) {
          accuracyInput.value = Number(position.coords.accuracy).toFixed(2);
        }
        syncGpsCoordinatesInputFromHidden();
        updateGpsStatus();
        refresh();
      }, () => {
        if (gpsStatus) gpsStatus.textContent = 'Impossible de récupérer la position. Vérifie l’autorisation GPS du navigateur.';
      }, {
        enableHighAccuracy: true,
        timeout: 12000,
        maximumAge: 60000
      });
    });
  }

  document.addEventListener('click', (event) => {
    const gpsButton = event.target.closest('[data-open-gps-field]');
    if (!gpsButton) {
      return;
    }

    event.preventDefault();

    const details = document.getElementById('checkout-address-details');
    openDetails(details);

    const gpsInput = document.getElementById('delivery-gps-coordinates');
    const target = gpsInput || details;

    if (target && target.scrollIntoView) {
      target.scrollIntoView({
        behavior: 'smooth',
        block: 'center'
      });
    }

    if (gpsInput && gpsInput.focus) {
      window.setTimeout(() => gpsInput.focus(), 250);
    }
  });

  form.querySelectorAll('[data-delivery-point-slot-select]').forEach((select) => {
    select.addEventListener('change', () => applyDeliveryPointSlotSelect(select));
  });

  ['#checkout_deliveryPointRequestedDate', '#checkout_deliveryPointCustomerInstructions'].forEach((selector) => {
    const input = form.querySelector(selector);
    if (!input) return;
    input.addEventListener('input', () => {
      if (selector === '#checkout_deliveryPointRequestedDate') refreshDeliveryPointSlots(true);
      updateDeliveryPointCurrentSummary();
      refresh();
    });
    input.addEventListener('change', () => {
      if (selector === '#checkout_deliveryPointRequestedDate') refreshDeliveryPointSlots(true);
      updateDeliveryPointCurrentSummary();
      refresh();
    });
  });

  const initialDeliveryPoint = getDeliveryPointElements();
  if (initialDeliveryPoint.section) {
    setDeliveryMethod(initialDeliveryPoint.section.dataset.pointRequired === '1' ? 'DELIVERY_POINT' : (initialDeliveryPoint.methodInput ? initialDeliveryPoint.methodInput.value : 'STANDARD'));
    const selectedPointCard = initialDeliveryPoint.cards.find((card) => initialDeliveryPoint.pointInput && card.dataset.pointId === initialDeliveryPoint.pointInput.value);
    if ((initialDeliveryPoint.section.dataset.pointRequired === '1' || (initialDeliveryPoint.methodInput && initialDeliveryPoint.methodInput.value === 'DELIVERY_POINT')) && (selectedPointCard || initialDeliveryPoint.cards[0])) {
      applyDeliveryPointCard(selectedPointCard || initialDeliveryPoint.cards[0]);
    } else {
      refreshDeliveryPointWindows();
    }
  }

  const serverAlert = document.querySelector('[data-checkout-server-alert]');
  if (serverAlert && serverAlert.scrollIntoView) {
    window.setTimeout(() => {
      serverAlert.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 80);
  }

  applyPostalCodeFilter({ autoSelectSingle: true });
  applyCommuneMetadata();
  syncGpsCoordinatesInputFromHidden();
  updateGpsStatus();
  refreshLogisticsPreview();
  refresh();
})();
</script>
    {% endif %}
  </div>
</section>
{% endblock %}

