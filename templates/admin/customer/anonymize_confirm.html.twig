{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    Anonymiser un client
{% endblock %}

{% block main %}
    <style>
        .hodina-anonymize-card {
            max-width: 820px;
            border: 1px solid rgba(217, 119, 6, .35);
            border-radius: 22px;
            padding: 1.4rem;
            background: var(--body-bg, #fff);
            box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
        }

        .hodina-warning-box {
            border-radius: 16px;
            padding: 1rem;
            background: rgba(217, 119, 6, .12);
            border: 1px solid rgba(217, 119, 6, .35);
            margin: 1rem 0;
        }

        .hodina-keep-box {
            border-radius: 16px;
            padding: 1rem;
            background: rgba(16, 185, 129, .1);
            border: 1px solid rgba(16, 185, 129, .3);
            margin: 1rem 0;
        }

        .hodina-summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: .75rem;
            margin: 1rem 0;
        }

        .hodina-summary-item {
            border: 1px solid rgba(148, 163, 184, .35);
            border-radius: 16px;
            padding: 1rem;
        }

        .hodina-summary-number {
            display: block;
            font-size: 2rem;
            font-weight: 900;
            line-height: 1;
        }

        .hodina-actions {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            margin-top: 1.25rem;
        }

        .hodina-actions .btn {
            border-radius: 14px;
            padding: .75rem 1rem;
            font-weight: 800;
        }
    </style>

    <div class="hodina-anonymize-card">
        <p class="text-muted mb-2">Anonymisation RGPD — conserve l'historique métier, supprime l'identité.</p>

        <h2 class="h4 mb-3">Client concerné</h2>
        <dl class="row">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">#{{ customer.id }}</dd>

            <dt class="col-sm-4">Nom</dt>
            <dd class="col-sm-8">{{ customer.firstName }} {{ customer.lastName }}</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">{{ customer.email ?: 'Non renseigné' }}</dd>

            <dt class="col-sm-4">Téléphone</dt>
            <dd class="col-sm-8">{{ customer.phone ?: 'Non renseigné' }}</dd>
        </dl>

        <div class="hodina-warning-box">
            <strong>Action non réversible.</strong>
            <p class="mb-0 mt-2">
                Nom, prénom, téléphone, email et mot de passe sont remplacés par des valeurs génériques.
                Les adresses du client sont supprimées. La connexion à ce compte est bloquée immédiatement.
                Les données d'origine ne sont conservées nulle part.
            </p>
        </div>

        <div class="hodina-keep-box">
            <strong>Ce qui reste conservé (traçabilité opérationnelle).</strong>
            <p class="mb-0 mt-2">
                Commandes, tickets support, conversations avec l'assistant IA et paiements livreur restent
                rattachés à cette fiche client — leur contenu n'est pas modifié, seule l'identité du client
                devient anonyme.
            </p>
        </div>

        <h3 class="h5">Ce qui sera supprimé</h3>
        <div class="hodina-summary-grid">
            <div class="hodina-summary-item">
                <span class="hodina-summary-number">{{ preview.addresses }}</span>
                adresse(s)
            </div>
        </div>

        <form method="post" class="hodina-actions">
            <input type="hidden" name="_token" value="{{ csrf_token('anonymize_customer_' ~ customer.id) }}">

            <button type="submit" class="btn btn-warning">
                Confirmer l'anonymisation
            </button>

            <a href="{{ cancelUrl }}" class="btn btn-secondary">
                Annuler
            </a>
        </form>
    </div>
{% endblock %}
