{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    {{ title }}
{% endblock %}

{% block main %}
    <style>
        .hodina-delete-card {
            max-width: 820px;
            border: 1px solid rgba(239, 68, 68, .35);
            border-radius: 22px;
            padding: 1.4rem;
            background: var(--body-bg, #fff);
            box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
        }

        .hodina-danger-box {
            border-radius: 16px;
            padding: 1rem;
            background: rgba(239, 68, 68, .12);
            border: 1px solid rgba(239, 68, 68, .35);
            margin: 1rem 0;
        }

        .hodina-summary-item {
            display: inline-block;
            border: 1px solid rgba(148, 163, 184, .35);
            border-radius: 16px;
            padding: 1rem 1.5rem;
            margin: 1rem 0;
        }

        .hodina-summary-number {
            display: block;
            font-size: 2rem;
            font-weight: 900;
            line-height: 1;
        }

        .hodina-actions {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            margin-top: 1.25rem;
        }

        .hodina-actions .btn {
            border-radius: 14px;
            padding: .75rem 1rem;
            font-weight: 800;
        }
    </style>

    <div class="hodina-delete-card">
        <div class="hodina-danger-box">
            <strong>Suppression définitive.</strong>
            <p class="mb-0 mt-2">{{ warningText }}</p>
        </div>

        <div class="hodina-summary-item">
            <span class="hodina-summary-number">{{ count }}</span>
            {{ entityLabel }}
        </div>

        <form method="post" class="hodina-actions">
            <input type="hidden" name="_token" value="{{ csrf_token(csrfTokenId) }}">

            <button type="submit" class="btn btn-danger"{{ count == 0 ? ' disabled' : '' }}>
                Confirmer la suppression
            </button>

            <a href="{{ cancelUrl }}" class="btn btn-secondary">
                Annuler
            </a>
        </form>
    </div>
{% endblock %}
