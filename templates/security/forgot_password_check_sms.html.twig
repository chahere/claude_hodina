{% extends 'base.html.twig' %}

{% block title %}Lien SMS généré — Hodina{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .login-page { min-height: calc(100vh - 180px); display: flex; align-items: center; justify-content: center; padding: 32px 16px; background: radial-gradient(circle at top left, rgba(134, 90, 45, 0.16), transparent 32%), radial-gradient(circle at bottom right, rgba(33, 115, 70, 0.12), transparent 32%); }
        .login-card { width: 100%; max-width: 460px; background: #fffaf4; border: 1px solid rgba(96, 62, 30, 0.14); border-radius: 24px; box-shadow: 0 18px 50px rgba(41, 25, 12, 0.12); padding: 28px; }
        .login-eyebrow { margin: 0 0 8px; color: #8a5a2b; font-size: .82rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
        .login-title { margin: 0; color: #2b190d; font-size: clamp(1.7rem, 6vw, 2.25rem); line-height: 1.05; }
        .login-subtitle { margin: 12px 0 24px; color: #6e5a47; line-height: 1.45; }
        .login-actions { display: grid; gap: 12px; margin-top: 22px; }
        .login-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; border-radius: 999px; padding: 12px 18px; font-weight: 900; text-decoration: none; border: 1px solid transparent; cursor: pointer; font-size: 1rem; }
        .login-btn-primary { background: #2f7d4f; color: #fff; box-shadow: 0 10px 22px rgba(47, 125, 79, 0.22); }
        .login-btn-secondary { background: #fff; color: #2b190d; border-color: rgba(96, 62, 30, 0.22); }
    </style>
{% endblock %}

{% block body %}
    <section class="login-page">
        <div class="login-card">
            <p class="login-eyebrow">SMS pilote</p>
            <h1 class="login-title">Lien généré</h1>
            <p class="login-subtitle">
                Si le compte existe, un SmsLog vient d'être créé avec le lien de réinitialisation. Pendant le pilote, va dans le backoffice SMS logs et clique sur <strong>Envoyer le SMS</strong> pour ouvrir Messages sur iPhone.
            </p>
            <div class="login-actions">
                <a class="login-btn login-btn-primary" href="{{ path('app_login') }}">Retour connexion</a>
                <a class="login-btn login-btn-secondary" href="{{ path('product_catalogue') }}">Retour catalogue</a>
            </div>
        </div>
    </section>
{% endblock %}
