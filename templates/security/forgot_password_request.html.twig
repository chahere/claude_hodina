{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — Hodina{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .login-page { min-height: calc(100vh - 180px); display: flex; align-items: center; justify-content: center; padding: 32px 16px; background: radial-gradient(circle at top left, rgba(134, 90, 45, 0.16), transparent 32%), radial-gradient(circle at bottom right, rgba(33, 115, 70, 0.12), transparent 32%); }
        .login-card { width: 100%; max-width: 460px; background: #fffaf4; border: 1px solid rgba(96, 62, 30, 0.14); border-radius: 24px; box-shadow: 0 18px 50px rgba(41, 25, 12, 0.12); padding: 28px; }
        .login-eyebrow { margin: 0 0 8px; color: #8a5a2b; font-size: .82rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
        .login-title { margin: 0; color: #2b190d; font-size: clamp(1.7rem, 6vw, 2.25rem); line-height: 1.05; }
        .login-subtitle { margin: 12px 0 24px; color: #6e5a47; line-height: 1.45; }
        .login-field { margin-bottom: 16px; }
        .login-label { display: block; margin-bottom: 7px; color: #2b190d; font-weight: 800; }
        .login-input { width: 100%; box-sizing: border-box; border: 1px solid rgba(96, 62, 30, 0.22); border-radius: 14px; padding: 13px 14px; font-size: 1rem; background: #fff; color: #2b190d; }
        .login-input:focus { outline: none; border-color: #8a5a2b; box-shadow: 0 0 0 4px rgba(138, 90, 43, 0.14); }
        .login-actions { display: grid; gap: 12px; margin-top: 22px; }
        .login-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; border-radius: 999px; padding: 12px 18px; font-weight: 900; text-decoration: none; border: 1px solid transparent; cursor: pointer; font-size: 1rem; }
        .login-btn-primary { background: #2f7d4f; color: #fff; box-shadow: 0 10px 22px rgba(47, 125, 79, 0.22); }
        .login-btn-secondary { background: #fff; color: #2b190d; border-color: rgba(96, 62, 30, 0.22); }
        .login-error { margin: 6px 0 0; color: #9f1d1d; font-size: .9rem; font-weight: 700; }
        .login-help { margin: 16px 0 0; text-align: center; color: #6e5a47; font-size: .94rem; }
        .login-help a { color: #8a5a2b; font-weight: 800; }
        @media (max-width: 520px) { .login-page { align-items: flex-start; padding: 20px 12px 28px; } .login-card { padding: 22px; border-radius: 20px; } }
    </style>
{% endblock %}

{% block body %}
    <section class="login-page">
        <div class="login-card">
            <p class="login-eyebrow">Compte client Hodina</p>
            <h1 class="login-title">Mot de passe oublié</h1>
            <p class="login-subtitle">
                Saisis l'email du compte. Hodina générera un lien de réinitialisation et le placera dans les SMS logs pour envoi manuel par SMS pendant le pilote.
            </p>

            {{ form_start(requestForm) }}
                <div class="login-field">
                    {{ form_label(requestForm.email, null, {'label_attr': {'class': 'login-label'}}) }}
                    {{ form_widget(requestForm.email, {'attr': {'class': 'login-input'}}) }}
                    <div class="login-error">{{ form_errors(requestForm.email) }}</div>
                </div>

                <div class="login-actions">
                    <button type="submit" class="login-btn login-btn-primary">Générer le lien SMS</button>
                    <a class="login-btn login-btn-secondary" href="{{ path('app_login') }}">Retour connexion</a>
                </div>
            {{ form_end(requestForm) }}

            <p class="login-help">
                Tu veux simplement regarder les produits ?
                <a href="{{ path('product_catalogue') }}">Retour au catalogue</a>
            </p>
        </div>
    </section>
{% endblock %}
