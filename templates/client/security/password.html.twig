{% extends 'base.html.twig' %}

{% block title %}Sécurité du compte – Hodina{% endblock %}

{% block body %}
<section class="section account-page" data-client-account-page>
  <div class="container account-container">
    <div class="account-header">
      <p class="account-kicker">Mon compte</p>
      <h1>Sécurité</h1>
      <p class="muted">Modifie ton mot de passe ou demande un nouveau lien de réinitialisation.</p>
    </div>

    {% include 'client/_account_nav.html.twig' %}

    <article class="account-card account-form-card">
      <h2>Modifier mon mot de passe</h2>
      <p class="muted small">Pour protéger ton compte, l’ancien mot de passe est obligatoire.</p>

      {{ form_start(passwordForm, {'attr': {'class': 'account-form', 'data-client-account-form': 'password'}}) }}
        <div class="account-field">
          {{ form_label(passwordForm.currentPassword, null, {'label_attr': {'class': 'account-form-label'}}) }}
          {{ form_widget(passwordForm.currentPassword, {'attr': {'class': 'account-input'}}) }}
          <div class="account-form-error">{{ form_errors(passwordForm.currentPassword) }}</div>
        </div>

        <div class="account-field">
          {{ form_label(passwordForm.plainPassword.first, null, {'label_attr': {'class': 'account-form-label'}}) }}
          {{ form_widget(passwordForm.plainPassword.first, {'attr': {'class': 'account-input'}}) }}
          <div class="account-form-error">{{ form_errors(passwordForm.plainPassword.first) }}</div>
        </div>

        <div class="account-field">
          {{ form_label(passwordForm.plainPassword.second, null, {'label_attr': {'class': 'account-form-label'}}) }}
          {{ form_widget(passwordForm.plainPassword.second, {'attr': {'class': 'account-input'}}) }}
          <div class="account-form-error">{{ form_errors(passwordForm.plainPassword.second) }}</div>
          <div class="account-form-error">{{ form_errors(passwordForm.plainPassword) }}</div>
        </div>

        <div class="account-form-actions">
          <button type="submit" class="btn btn-primary">Modifier mon mot de passe</button>
          <a href="{{ path('client_account_index') }}" class="btn btn-secondary">Retour au compte</a>
        </div>
      {{ form_end(passwordForm) }}
    </article>

    <article class="account-card account-reset-card">
      <h2>Mot de passe oublié ?</h2>
      <p class="muted small">Hodina peut générer un lien de réinitialisation pour ton compte. Pendant le pilote, ce lien est préparé dans les SMS logs pour envoi manuel.</p>
      <form method="post" action="{{ path('client_security_reset_link_request') }}" class="account-reset-form" data-client-account-form="reset-link">
        <input type="hidden" name="_token" value="{{ csrf_token('client_password_reset_link') }}">
        <button type="submit" class="btn btn-secondary">Demander un lien de réinitialisation</button>
      </form>
    </article>
  </div>
</section>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  {% include 'client/_account_ajax.html.twig' %}
{% endblock %}
