{% extends 'base.html.twig' %}

{% block title %}Hodina — Produits locaux de Mayotte{% endblock %}

{% block body %}
    {# HERO #}
    <section class="hero">
        <div class="container">
            <p class="badge">Pilote en cours • Mayotte</p>

            <h1>La marketplace locale pour les produits de Mayotte</h1>

            <p class="hero-sub">
                Hodina connecte les producteurs et vendeurs mahorais
                avec les clients locaux, via une plateforme simple et humaine.
            </p>

            <div class="hero-actions">
                <a href="{{ path('product_catalogue') }}" class="btn btn-primary">
                    Voir le catalogue
                </a>
                <a href="#devenir-vendeur" class="btn btn-secondary">
                    Devenir vendeur
                </a>
            </div>
        </div>
    </section>

    {# POUR LES VENDEURS #}
    <section class="section benefits">
        <div class="container">
            <h2>Vous êtes vendeur ou producteur ?</h2>

            <ul class="checklist">
                <li>Vous fixez vos prix</li>
                <li>Vos produits sont visibles en ligne</li>
                <li>Les commandes sont validées avec vous</li>
                <li>Livraison organisée selon votre zone (PT / GT)</li>
            </ul>
        </div>
    </section>

    {# COMMENT ÇA MARCHE #}
    <section class="section how">
        <div class="container">
            <h2>Comment ça marche</h2>

            <ol class="steps">
                <li>
                    <span class="step-num">1</span>
                    <div>
                        <strong>Vous rejoignez le pilote</strong><br>
                        Contact simple (WhatsApp / appel)
                    </div>
                </li>
                <li>
                    <span class="step-num">2</span>
                    <div>
                        <strong>Vos produits sont ajoutés</strong><br>
                        Nom, prix, stock, zone
                    </div>
                </li>
                <li>
                    <span class="step-num">3</span>
                    <div>
                        <strong>Les clients commandent</strong><br>
                        Via le catalogue en ligne
                    </div>
                </li>
                <li>
                    <span class="step-num">4</span>
                    <div>
                        <strong>Validation + livraison</strong><br>
                        Après confirmation avec vous
                    </div>
                </li>
            </ol>
        </div>
    </section>

    {# CTA #}
    <section id="devenir-vendeur" class="section cta">
        <div class="container">
            <h2>Rejoindre le pilote Hodina</h2>

            <p class="muted">
                Le pilote est en cours à Mayotte.
                Nous intégrons progressivement les vendeurs locaux.
            </p>

            <div class="cta-actions">
                <a
                    class="btn btn-primary"
                    href="https://wa.me/262XXXXXXXXX"
                    target="_blank"
                >
                    Contacter Hodina sur WhatsApp
                </a>

                <a class="btn btn-secondary" href="{{ path('product_catalogue') }}">
                    Voir la démo catalogue
                </a>
            </div>
        </div>
    </section>
{% endblock %}
