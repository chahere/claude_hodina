{% extends 'base.html.twig' %}

{% block title %}Créer mon compte — Hodina{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .register-page {
            min-height: calc(100vh - 180px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
            background:
                radial-gradient(circle at top left, rgba(134, 90, 45, 0.16), transparent 32%),
                radial-gradient(circle at bottom right, rgba(33, 115, 70, 0.12), transparent 32%);
        }

        .register-card {
            width: 100%;
            max-width: 460px;
            background: #fffaf4;
            border: 1px solid rgba(96, 62, 30, 0.14);
            border-radius: 24px;
            box-shadow: 0 18px 50px rgba(41, 25, 12, 0.12);
            padding: 28px;
        }

        .register-eyebrow {
            margin: 0 0 8px;
            color: #8a5a2b;
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .register-title {
            margin: 0;
            color: #2b190d;
            font-size: clamp(1.7rem, 6vw, 2.25rem);
            line-height: 1.05;
        }

        .register-subtitle {
            margin: 12px 0 24px;
            color: #6e5a47;
            line-height: 1.45;
        }

        .register-alert,
        .register-errors {
            margin-bottom: 18px;
            padding: 12px 14px;
            border-radius: 14px;
            background: #fff0f0;
            color: #9f1d1d;
            border: 1px solid rgba(159, 29, 29, 0.18);
            font-weight: 700;
        }

        .register-field {
            margin-bottom: 16px;
        }

        .register-label {
            display: block;
            margin-bottom: 7px;
            color: #2b190d;
            font-weight: 800;
        }

        .register-input {
            width: 100%;
            box-sizing: border-box;
            border: 1px solid rgba(96, 62, 30, 0.22);
            border-radius: 14px;
            padding: 13px 14px;
            font-size: 1rem;
            background: #fff;
            color: #2b190d;
        }

        .register-input:focus {
            outline: none;
            border-color: #8a5a2b;
            box-shadow: 0 0 0 4px rgba(138, 90, 43, 0.14);
        }

        .register-error-list {
            margin: 7px 0 0;
            padding-left: 18px;
            color: #9f1d1d;
            font-size: 0.92rem;
            font-weight: 700;
        }

        .register-terms {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            margin: 18px 0 4px;
            color: #2b190d;
            font-weight: 700;
            line-height: 1.35;
        }

        .register-terms input {
            width: 20px;
            height: 20px;
            margin-top: 1px;
            accent-color: #2f7d4f;
            flex: 0 0 auto;
        }

        .register-terms a {
            color: #2f7d4f;
            font-weight: 900;
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        .register-terms a:hover {
            color: #25683f;
        }

        .register-actions {
            display: grid;
            gap: 12px;
            margin-top: 22px;
        }

        .register-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 48px;
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 900;
            text-decoration: none;
            border: 1px solid transparent;
            cursor: pointer;
            font-size: 1rem;
        }

        .register-btn-primary {
            background: #2f7d4f;
            color: #fff;
            box-shadow: 0 10px 22px rgba(47, 125, 79, 0.22);
        }

        .register-btn-secondary {
            background: #fff;
            color: #2b190d;
            border-color: rgba(96, 62, 30, 0.22);
        }

        .register-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 22px 0 12px;
            color: #8b7a6b;
            font-size: 0.9rem;
        }

        .register-divider::before,
        .register-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(96, 62, 30, 0.16);
        }

        .register-help {
            margin: 16px 0 0;
            text-align: center;
            color: #6e5a47;
            font-size: 0.94rem;
        }

        .register-help a {
            color: #8a5a2b;
            font-weight: 800;
        }

        @media (max-width: 520px) {
            .register-page {
                align-items: flex-start;
                padding: 20px 12px 28px;
            }

            .register-card {
                padding: 22px;
                border-radius: 20px;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="register-page">
        <div class="register-card">
            <p class="register-eyebrow">Espace client Hodina</p>
            <h1 class="register-title">Créer mon compte</h1>
            <p class="register-subtitle">
                Crée ton compte pour valider ton panier, renseigner ton téléphone et suivre tes commandes Hodina.
            </p>

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="register-alert" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {% for flash_error in app.flashes('register_error') %}
                <div class="register-alert" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {% if registrationForm.vars.errors|length > 0 %}
                <div class="register-errors" role="alert">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            {{ form_start(registrationForm) }}
                <div class="register-field">
                    {{ form_label(registrationForm.firstName, 'Prénom', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.firstName, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'given-name',
                            'placeholder': 'Ton prénom'
                        }
                    }) }}
                    {% if registrationForm.firstName.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.firstName) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    {{ form_label(registrationForm.lastName, 'Nom', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.lastName, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'family-name',
                            'placeholder': 'Ton nom'
                        }
                    }) }}
                    {% if registrationForm.lastName.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.lastName) }}</div>
                    {% endif %}
                </div>

                <div class="register-field{% if registrationForm.phone.vars.errors|length > 0 or registrationForm.phoneCountryCode.vars.errors|length > 0 %} has-error{% endif %}">
                    {{ form_label(registrationForm.phone, 'Téléphone', {'label_attr': {'class': 'register-label'}}) }}
                    <div class="phone-input-row">
                        {{ form_widget(registrationForm.phoneCountryCode, {
                            'attr': {
                                'class': 'register-input phone-country-code',
                                'autocomplete': 'tel-country-code'
                            }
                        }) }}
                        {{ form_widget(registrationForm.phone, {
                            'attr': {
                                'class': 'register-input phone-local-number',
                                'autocomplete': 'tel-national',
                                'inputmode': 'tel',
                                'placeholder': 'Ex : 0639 12 34 56'
                            }
                        }) }}
                    </div>
                    <p class="muted small">Choisis l’indicatif puis saisis le numéro local. Les fixes sont acceptés.</p>
                    {% if registrationForm.phoneCountryCode.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.phoneCountryCode) }}</div>
                    {% endif %}
                    {% if registrationForm.phone.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.phone) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    {{ form_label(registrationForm.email, 'Adresse email', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'email',
                            'placeholder': 'exemple@email.com'
                        }
                    }) }}
                    {% if registrationForm.email.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.email) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    <h2 style="font-size:1.05rem; margin: 10px 0 4px;">Adresse de livraison</h2>
                    <p class="register-help" style="text-align:left; margin:0 0 10px;">
                        La livraison doit correspondre à une commune livrable Hodina en Petite-Terre ou Grande-Terre.
                    </p>
                </div>

                <div class="register-field">
                    {{ form_label(registrationForm.address, 'Adresse de livraison', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.address, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'street-address',
                            'placeholder': 'Ex : 3 rue Mariam Ali'
                        }
                    }) }}
                    {% if registrationForm.address.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.address) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    {{ form_label(registrationForm.postalCode, 'Code postal de livraison', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.postalCode, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'postal-code',
                            'inputmode': 'numeric',
                            'placeholder': 'Ex : 97615'
                        }
                    }) }}
                    {% if registrationForm.postalCode.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.postalCode) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    {{ form_label(registrationForm.commune, 'Commune de livraison', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.commune, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'address-level2',
                            'placeholder': 'Ex : Labattoir, Dzaoudzi, Mamoudzou'
                        }
                    }) }}
                    {% if registrationForm.commune.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.commune) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    {{ form_label(registrationForm.zone, 'Zone de livraison', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.zone, {
                        'attr': {
                            'class': 'register-input'
                        }
                    }) }}
                    {% if registrationForm.zone.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.zone) }}</div>
                    {% endif %}
                </div>

                <div class="register-field">
                    <h2 style="font-size:1.05rem; margin: 16px 0 4px;">Adresse de facturation</h2>
                    <p class="register-help" style="text-align:left; margin:0 0 10px;">
                        La facturation peut être hors zone livrable ou à Mayotte. Choisis AUTRE pour une adresse hors zone livrable, ou PT/GT pour une adresse de facturation à Mayotte.
                    </p>
                </div>

                <label class="register-terms" for="{{ registrationForm.useBillingSameAsDelivery.vars.id }}">
                    {{ form_widget(registrationForm.useBillingSameAsDelivery) }}
                    <span>Utiliser cette adresse aussi pour la facturation</span>
                </label>
                {% if registrationForm.useBillingSameAsDelivery.vars.errors|length > 0 %}
                    <div class="client-form-errors">{{ form_errors(registrationForm.useBillingSameAsDelivery) }}</div>
                {% endif %}

                <div id="registration-billing-fields">
                    <div class="register-field">
                        {{ form_label(registrationForm.billingAddress, 'Adresse de facturation', {'label_attr': {'class': 'register-label'}}) }}
                        {{ form_widget(registrationForm.billingAddress, {
                            'attr': {
                                'class': 'register-input',
                                'autocomplete': 'billing street-address',
                                'placeholder': 'Ex : 12 rue de Rennes'
                            }
                        }) }}
                        {% if registrationForm.billingAddress.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.billingAddress) }}</div>
                    {% endif %}
                    </div>

                    <div class="register-field">
                        {{ form_label(registrationForm.billingPostalCode, 'Code postal de facturation', {'label_attr': {'class': 'register-label'}}) }}
                        {{ form_widget(registrationForm.billingPostalCode, {
                            'attr': {
                                'class': 'register-input',
                                'autocomplete': 'billing postal-code',
                                'inputmode': 'numeric',
                                'placeholder': 'Ex : 35000'
                            }
                        }) }}
                        {% if registrationForm.billingPostalCode.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.billingPostalCode) }}</div>
                    {% endif %}
                    </div>

                    <div class="register-field">
                        {{ form_label(registrationForm.billingCommune, 'Commune de facturation', {'label_attr': {'class': 'register-label'}}) }}
                        {{ form_widget(registrationForm.billingCommune, {
                            'attr': {
                                'class': 'register-input',
                                'autocomplete': 'billing address-level2',
                                'placeholder': 'Ex : Rennes'
                            }
                        }) }}
                        {% if registrationForm.billingCommune.vars.errors|length > 0 %}
                            <div class="client-form-errors">{{ form_errors(registrationForm.billingCommune) }}</div>
                        {% endif %}
                    </div>

                    <div class="register-field">
                        {{ form_label(registrationForm.billingZone, 'Zone de facturation', {'label_attr': {'class': 'register-label'}}) }}
                        {{ form_widget(registrationForm.billingZone, {
                            'attr': {
                                'class': 'register-input'
                            }
                        }) }}
                        <p class="register-help" style="text-align:left; margin:7px 0 0;">
                            AUTRE pour une facturation hors zone livrable. PT/GT si l’adresse de facturation est à Mayotte.
                        </p>
                        {% if registrationForm.billingZone.vars.errors|length > 0 %}
                            <div class="client-form-errors">{{ form_errors(registrationForm.billingZone) }}</div>
                        {% endif %}
                    </div>
                </div>

                <script>
                    (function(){
                        const checkbox = document.getElementById('{{ registrationForm.useBillingSameAsDelivery.vars.id }}');
                        const fields = document.getElementById('registration-billing-fields');
                        if (!checkbox || !fields) return;
                        const refresh = () => { fields.style.display = checkbox.checked ? 'none' : 'block'; };
                        checkbox.addEventListener('change', refresh);
                        refresh();
                    })();
                </script>

                <div class="register-field">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'register-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'register-input',
                            'autocomplete': 'new-password',
                            'placeholder': 'Minimum 6 caractères'
                        }
                    }) }}
                    {% if registrationForm.plainPassword.vars.errors|length > 0 %}
                        <div class="client-form-errors">{{ form_errors(registrationForm.plainPassword) }}</div>
                    {% endif %}
                </div>

                <label class="register-terms" for="{{ registrationForm.agreeTerms.vars.id }}">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <span>
                        J’accepte les
                        <a href="{{ path('app_cgu') }}" target="_blank" rel="noopener noreferrer">CGU</a>
                        et les
                        <a href="{{ path('app_cgv') }}" target="_blank" rel="noopener noreferrer">CGV</a>
                        de Hodina.
                    </span>
                </label>
                {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                    <div class="client-form-errors">{{ form_errors(registrationForm.agreeTerms) }}</div>
                {% endif %}

                <div class="register-actions">
                    <button type="submit" class="register-btn register-btn-primary">
                        Créer mon compte Hodina
                    </button>
                </div>

                {{ form_rest(registrationForm) }}
            {{ form_end(registrationForm, {'render_rest': false}) }}

            <div class="register-divider">ou</div>

            <a class="register-btn register-btn-secondary" href="{{ path('app_login') }}">
                J’ai déjà un compte
            </a>

            <p class="register-help">
                Tu veux juste regarder les produits ?
                <a href="{{ path('product_catalogue') }}">Retour au catalogue</a>
            </p>
        </div>
    </section>
{% endblock %}
