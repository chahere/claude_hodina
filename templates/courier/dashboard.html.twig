{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const ROOT_SELECTOR = '[data-djama-root]';
            const FORM_SELECTOR = 'form[data-djama-ajax="true"]';

            function getRoot() {
                return document.querySelector(ROOT_SELECTOR);
            }

            function rememberOpenCards(extraOrderId) {
                const openOrderIds = Array.from(document.querySelectorAll('.courier-card[open][data-djama-order-id]'))
                    .map((card) => card.dataset.djamaOrderId || '')
                    .filter(Boolean);

                if (extraOrderId) {
                    openOrderIds.push(String(extraOrderId));
                }

                return Array.from(new Set(openOrderIds));
            }

            function restoreOpenCards(openOrderIds) {
                if (!openOrderIds.length) {
                    return;
                }

                const openSet = new Set(openOrderIds.map(String));
                document.querySelectorAll('.courier-card[data-djama-order-id]').forEach((card) => {
                    const orderId = card.dataset.djamaOrderId || '';
                    if (orderId && openSet.has(orderId)) {
                        card.open = true;
                    }
                });
            }

            function ensureFlashContainer() {
                const root = getRoot();
                if (!root) {
                    return null;
                }

                let container = root.querySelector('[data-djama-flashes]');
                if (container) {
                    return container;
                }

                container = document.createElement('div');
                container.className = 'courier-flashes';
                container.setAttribute('aria-live', 'polite');
                container.dataset.djamaFlashes = '';

                const hero = root.querySelector('.courier-hero');
                if (hero && hero.nextSibling) {
                    root.insertBefore(container, hero.nextSibling);
                } else {
                    root.prepend(container);
                }

                return container;
            }

            function showLocalMessage(type, message) {
                const container = ensureFlashContainer();
                if (!container || !message) {
                    return;
                }

                const alert = document.createElement('div');
                alert.className = `courier-alert courier-alert--${type || 'info'}`;
                alert.textContent = message;
                container.replaceChildren(alert);
            }

            async function refreshDashboard(refreshUrl, forceOpenOrderId) {
                const root = getRoot();
                if (!root) {
                    window.location.reload();
                    return;
                }

                const openKeys = rememberOpenCards(forceOpenOrderId);
                const response = await fetch(refreshUrl || window.location.href, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                });

                if (!response.ok) {
                    throw new Error('Rafraîchissement Djama impossible.');
                }

                const html = await response.text();
                const nextDocument = new DOMParser().parseFromString(html, 'text/html');
                const nextRoot = nextDocument.querySelector(ROOT_SELECTOR);

                if (!nextRoot) {
                    throw new Error('Réponse Djama incomplète.');
                }

                root.replaceWith(nextRoot);
                restoreOpenCards(openKeys);
            }

            function setFormBusy(form, busy) {
                form.dataset.djamaBusy = busy ? '1' : '0';
                form.querySelectorAll('button, input, textarea, select').forEach((field) => {
                    if (busy) {
                        field.dataset.djamaWasDisabled = field.disabled ? '1' : '0';
                        field.disabled = true;
                    } else if (field.dataset.djamaWasDisabled !== '1') {
                        field.disabled = false;
                    }
                });

                const button = form.querySelector('button[type="submit"]');
                if (!button) {
                    return;
                }

                if (busy) {
                    button.dataset.djamaOriginalText = button.textContent;
                    button.classList.add('courier-btn--loading');
                    button.textContent = 'Traitement...';
                } else {
                    button.classList.remove('courier-btn--loading');
                    if (button.dataset.djamaOriginalText) {
                        button.textContent = button.dataset.djamaOriginalText;
                    }
                }
            }

            async function submitAjaxForm(form) {
                if (form.dataset.djamaBusy === '1') {
                    return;
                }

                // Important : construire FormData AVANT de désactiver les champs.
                // Un champ disabled n'est pas envoyé par FormData.
                const formData = new FormData(form);
                const forceOpenOrderId = form.closest('.courier-card')?.dataset.djamaOrderId || '';

                setFormBusy(form, true);

                try {
                    const response = await fetch(form.action, {
                        method: (form.method || 'POST').toUpperCase(),
                        body: formData,
                        headers: {
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                        credentials: 'same-origin',
                    });

                    const contentType = response.headers.get('content-type') || '';
                    if (!contentType.includes('application/json')) {
                        window.location.reload();
                        return;
                    }

                    const payload = await response.json();

                    await refreshDashboard(payload.refreshUrl || window.location.href, forceOpenOrderId);

                    showLocalMessage(
                        payload.flashType || (payload.ok ? 'success' : 'warning'),
                        payload.message || 'Action traitée.'
                    );
                } catch (error) {
                    showLocalMessage('danger', error instanceof Error ? error.message : 'Action impossible. Recharge la page puis réessaie.');
                } finally {
                    const stillConnected = document.documentElement.contains(form);
                    if (stillConnected) {
                        setFormBusy(form, false);
                    }
                }
            }

            document.addEventListener('submit', (event) => {
                const form = event.target instanceof HTMLFormElement ? event.target : null;
                if (!form || !form.matches(FORM_SELECTOR)) {
                    return;
                }

                event.preventDefault();
                submitAjaxForm(form);
            });
        })();
    </script>
