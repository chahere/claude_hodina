{% extends 'base.html.twig' %}

{% block title %}Nous contacter — Hodina{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .contact-page {
            min-height: calc(100vh - 180px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
        }

        .contact-card {
            width: 100%;
            max-width: 560px;
            background: #fffaf4;
            border: 1px solid rgba(96, 62, 30, 0.14);
            border-radius: 24px;
            box-shadow: 0 18px 50px rgba(41, 25, 12, 0.12);
            padding: 28px;
        }

        .contact-eyebrow {
            margin: 0 0 8px;
            color: #8a5a2b;
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .contact-title {
            margin: 0;
            color: #2b190d;
            font-size: clamp(1.7rem, 6vw, 2.25rem);
            line-height: 1.05;
        }

        .contact-subtitle {
            margin: 12px 0 24px;
            color: #6e5a47;
            line-height: 1.45;
        }

        .contact-field {
            margin-bottom: 16px;
        }

        .contact-label {
            display: block;
            margin-bottom: 7px;
            color: #2b190d;
            font-weight: 800;
        }

        .contact-input {
            width: 100%;
            box-sizing: border-box;
            border: 1px solid rgba(96, 62, 30, 0.22);
            border-radius: 14px;
            padding: 13px 14px;
            font-size: 1rem;
            background: #fff;
            color: #2b190d;
            font-family: inherit;
        }

        .contact-input:focus {
            outline: none;
            border-color: #8a5a2b;
            box-shadow: 0 0 0 4px rgba(138, 90, 43, 0.14);
        }

        .contact-form-errors {
            margin: 7px 0 0;
            color: #9f1d1d;
            font-size: 0.92rem;
            font-weight: 700;
        }

        .contact-honeypot {
            position: absolute;
            left: -5000px;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        .contact-actions {
            margin-top: 22px;
        }

        .contact-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 48px;
            width: 100%;
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 900;
            text-decoration: none;
            border: 1px solid transparent;
            cursor: pointer;
            font-size: 1rem;
            background: #2f7d4f;
            color: #fff;
            box-shadow: 0 10px 22px rgba(47, 125, 79, 0.22);
        }
    </style>
{% endblock %}

{% block body %}
    <section class="contact-page">
        <div class="contact-card">
            <p class="contact-eyebrow">Assistance Hodina</p>
            <h1 class="contact-title">Nous contacter</h1>
            <p class="contact-subtitle">
                Une question sur une commande, une livraison ou le catalogue ? Écris-nous, notre équipe te répond rapidement.
            </p>

            {{ form_start(form) }}
                <div class="contact-field">
                    {{ form_label(form.name, 'Nom', {'label_attr': {'class': 'contact-label'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'contact-input', 'autocomplete': 'name'}}) }}
                    {% if form.name.vars.errors|length > 0 %}
                        <div class="contact-form-errors">{{ form_errors(form.name) }}</div>
                    {% endif %}
                </div>

                <div class="contact-field">
                    {{ form_label(form.email, 'E-mail', {'label_attr': {'class': 'contact-label'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'contact-input', 'autocomplete': 'email'}}) }}
                    {% if form.email.vars.errors|length > 0 %}
                        <div class="contact-form-errors">{{ form_errors(form.email) }}</div>
                    {% endif %}
                </div>

                <div class="contact-field">
                    {{ form_label(form.phone, 'Téléphone (optionnel)', {'label_attr': {'class': 'contact-label'}}) }}
                    {{ form_widget(form.phone, {'attr': {'class': 'contact-input', 'autocomplete': 'tel'}}) }}
                    {% if form.phone.vars.errors|length > 0 %}
                        <div class="contact-form-errors">{{ form_errors(form.phone) }}</div>
                    {% endif %}
                </div>

                <div class="contact-field">
                    {{ form_label(form.subject, 'Sujet', {'label_attr': {'class': 'contact-label'}}) }}
                    {{ form_widget(form.subject, {'attr': {'class': 'contact-input'}}) }}
                    {% if form.subject.vars.errors|length > 0 %}
                        <div class="contact-form-errors">{{ form_errors(form.subject) }}</div>
                    {% endif %}
                </div>

                <div class="contact-field">
                    {{ form_label(form.message, 'Message', {'label_attr': {'class': 'contact-label'}}) }}
                    {{ form_widget(form.message, {'attr': {'class': 'contact-input', 'rows': 6}}) }}
                    {% if form.message.vars.errors|length > 0 %}
                        <div class="contact-form-errors">{{ form_errors(form.message) }}</div>
                    {% endif %}
                </div>

                <div class="contact-honeypot" aria-hidden="true">
                    {{ form_label(form.website, 'Site web') }}
                    {{ form_widget(form.website, {'attr': {'tabindex': '-1', 'autocomplete': 'off'}}) }}
                </div>

                <div class="contact-actions">
                    <button type="submit" class="contact-btn">Envoyer le message</button>
                </div>

                {{ form_rest(form) }}
            {{ form_end(form, {'render_rest': false}) }}
        </div>
    </section>
{% endblock %}
