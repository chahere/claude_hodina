/* ===========================
   Alerts (simple)
   =========================== */
.alert{
  margin: .7rem 0;
  padding: .85rem 1rem;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: #fff;
}
.alert-success{ border-color: rgba(31,122,95,.25); background: rgba(31,122,95,.06); }
.alert-danger{ border-color: rgba(160,20,20,.25); background: rgba(160,20,20,.06); }

/* ===========================
   Qty stepper (reusable)
   =========================== */
.qty-stepper{
  display:flex;
  align-items:center;
  gap: .35rem;
  border: 1px solid rgba(0,0,0,.14);
  border-radius: 12px;
  padding: .35rem;
  background: #fff;
  width: fit-content;
}
.qty-stepper button{
  width: 40px;
  height: 40px;
  border-radius: 10px;
  border: 1px solid rgba(0,0,0,.10);
  background: #f6faf8;
  font-size: 1.2rem;
  font-weight: 900;
  cursor:pointer;
}
.qty-stepper button:active{ transform: translateY(1px); }
.qty-stepper-input{
  width: 54px;
  height: 40px;
  border: none;
  outline: none;
  text-align:center;
  font-weight: 900;
  background: transparent;
}
.qty-stepper--sm button{ width: 38px; height: 38px; }
.qty-stepper--sm .qty-stepper-input{ height: 38px; width: 52px; }

/* Remove number arrows (nice on desktop) */
.qty-stepper input[type=number]::-webkit-outer-spin-button,
.qty-stepper input[type=number]::-webkit-inner-spin-button{ -webkit-appearance: none; margin: 0; }
.qty-stepper input[type=number]{ -moz-appearance: textfield; }

/* ===========================
   Cart - Mobile first
   =========================== */
.cart-page{ padding: 1rem 0 2rem; }

.cart-head{ margin: .8rem 0 1rem; }
.cart-title{ margin: 0; font-size: 2.0rem; }
.cart-sub{ margin: .45rem 0 0; }

.cart-layout{
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  align-items: start;
}

.cart-card{
  display:grid;
  grid-template-columns: 84px 1fr;
  gap: 12px;
  padding: 12px;
  border: 1px solid rgba(0,0,0,.08);
  border-radius: 16px;
  background: #fff;
  box-shadow: var(--shadow);
}

.cart-card-media{ width: 84px; }
.cart-card-img{
  width: 84px;
  height: 84px;
  border-radius: 14px;
  object-fit: cover;
  display:block;
  border: 1px solid rgba(0,0,0,.08);
  background: rgba(0,0,0,.03);
}
.cart-card-img--ph{
  display:grid;
  place-items:center;
  font-size: 1.4rem;
}

.cart-card-name{
  font-weight: 900;
  text-decoration:none;
  display:inline-block;
  margin-bottom: .25rem;
}
.cart-card-meta{ font-size: .92rem; }

.cart-card-bottom{
  margin-top: .7rem;
  display:grid;
  grid-template-columns: 1fr;
  gap: .65rem;
}

.cart-card-price .price,
.cart-card-subtotal .price{ font-weight: 900; }

.cart-card-actions{
  margin-top: .35rem;
}

.btn-link{
  background: transparent;
  border: none;
  padding: 0;
  font-weight: 900;
  cursor:pointer;
}
.btn-link.danger{ color: #9b1c1c; }

/* Summary (mobile = sticky bottom bar style) */
.summary-card{
  border: 1px solid rgba(0,0,0,.08);
  border-radius: 16px;
  background: #fff;
  padding: 14px;
  box-shadow: var(--shadow);
}
.summary-title{ margin: 0 0 .75rem; font-size: 1.25rem; }

.summary-row{
  display:flex;
  justify-content: space-between;
  padding: .55rem 0;
  border-bottom: 1px solid rgba(0,0,0,.06);
}
.summary-total{
  border-bottom: none;
  padding-top: .75rem;
  font-size: 1.15rem;
}
.summary-actions{
  display:grid;
  gap: 10px;
  margin-top: 12px;
}
.cart-note{ margin: .85rem 0 0; }

/* Desktop enhancements */
@media (min-width: 920px){
  .cart-layout{
    grid-template-columns: 1fr 320px;
    gap: 18px;
  }

  .cart-card{
    grid-template-columns: 92px 1fr;
    padding: 14px;
  }

  .cart-card-media{ width: 92px; }
  .cart-card-img{ width: 92px; height: 92px; }

  .cart-card-bottom{
    grid-template-columns: 1fr 180px 1fr;
    align-items: end;
    gap: 12px;
  }

  .summary-card{
    position: sticky;
    top: 14px;
  }
}
